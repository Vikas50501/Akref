<!doctype html>
<html class="no-js" lang="{{ request.locale.iso_code }}">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width,initial-scale=1,viewport-fit=cover">
  <meta http-equiv="X-UA-Compatible" content="IE=edge">
  <link rel="canonical" href="{{ canonical_url }}">
  <link rel="preconnect" href="https://cdn.shopify.com" crossorigin>

  {%- if settings.favicon != blank -%}
    <link rel="icon" type="image/png" href="{{ settings.favicon | image_url: width: 32, height: 32 }}">
    <link rel="apple-touch-icon" href="{{ settings.favicon | image_url: width: 180, height: 180 }}">
  {%- endif -%}

  <title>{{ page_title }}{% if current_tags %} &ndash; {{ 'general.meta.tags' | t: tags: current_tags | join: ', ' }}{% endif %}{% if current_page != 1 %} &ndash; {{ 'general.meta.page' | t: page: current_page }}{% endif %}{% unless page_title contains shop.name %} &ndash; {{ shop.name }}{% endunless %}</title>

  {%- if page_description -%}<meta name="description" content="{{ page_description | escape }}">{%- endif -%}

  {%- comment -%} SEO / social meta + JSON-LD — inlined into the layout for maximum reliability (no head-snippet dependency) {%- endcomment -%}
  {%- assign og_image = page_image | default: settings.share_image -%}
  <meta property="og:site_name" content="{{ shop.name }}">
  <meta property="og:url" content="{{ canonical_url }}">
  <meta property="og:title" content="{{ page_title | escape }}">
  <meta property="og:type" content="{% if request.page_type == 'product' %}product{% elsif request.page_type == 'article' %}article{% else %}website{% endif %}">
  {%- if page_description -%}<meta property="og:description" content="{{ page_description | escape }}">{%- endif -%}
  {%- if og_image -%}
    <meta property="og:image" content="https:{{ og_image | image_url: width: 1200 }}">
    <meta property="og:image:secure_url" content="https:{{ og_image | image_url: width: 1200 }}">
  {%- endif -%}
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content="{{ page_title | escape }}">
  {%- if page_description -%}<meta name="twitter:description" content="{{ page_description | escape }}">{%- endif -%}
  {%- if og_image -%}<meta name="twitter:image" content="https:{{ og_image | image_url: width: 1200 }}">{%- endif -%}
  {%- if settings.social_twitter_handle != blank -%}<meta name="twitter:site" content="{{ settings.social_twitter_handle }}">{%- endif -%}
  {%- capture social_links -%}
    {%- assign sep = '' -%}
    {%- if settings.social_instagram != blank -%}{{ sep }}{{ settings.social_instagram | json }}{%- assign sep = ',' -%}{%- endif -%}
    {%- if settings.social_facebook != blank -%}{{ sep }}{{ settings.social_facebook | json }}{%- assign sep = ',' -%}{%- endif -%}
    {%- if settings.social_youtube != blank -%}{{ sep }}{{ settings.social_youtube | json }}{%- assign sep = ',' -%}{%- endif -%}
  {%- endcapture -%}
  {%- assign social_trim = social_links | strip -%}
  <script type="application/ld+json">
{ "@context": "https://schema.org", "@type": "Organization", "name": {{ shop.name | json }}, "url": {{ shop.url | append: '/' | json }}{% if settings.logo_dark %}, "logo": {{ settings.logo_dark | image_url: width: 500 | prepend: 'https:' | json }}{% endif %}{% if social_trim != blank %}, "sameAs": [{{ social_trim }}]{% endif %} }
  </script>
  <script type="application/ld+json">
{ "@context": "https://schema.org", "@type": "WebSite", "name": {{ shop.name | json }}, "url": {{ shop.url | append: '/' | json }}, "potentialAction": { "@type": "SearchAction", "target": "{{ shop.url }}{{ routes.search_url }}?q={search_term_string}", "query-input": "required name=search_term_string" } }
  </script>

  {%- render 'font-face' -%}{%- comment -%} font-face snippet also preloads the two critical fonts (queens heading serif + centra body). {%- endcomment -%}

  {{ content_for_header }}

  {{ 'base.css' | asset_url | stylesheet_tag }}
  {%- render 'css-settings' -%}
  {{ 'animations.css' | asset_url | stylesheet_tag }}
  {{ 'product-card.css' | asset_url | stylesheet_tag }}
  {{ 'component-header.css' | asset_url | stylesheet_tag }}
  {{ 'component-footer.css' | asset_url | stylesheet_tag }}
  {{ 'component-cart.css' | asset_url | stylesheet_tag }}
  {{ 'sections.css' | asset_url | stylesheet_tag }}
  {%- if request.page_type == 'product' -%}{{ 'component-product.css' | asset_url | stylesheet_tag }}{%- endif -%}
  {%- if request.page_type == 'collection' or request.page_type == 'search' or request.page_type == 'list-collections' -%}{{ 'component-collection.css' | asset_url | stylesheet_tag }}{%- endif -%}
  {%- if request.page_type == 'article' or request.page_type == 'blog' -%}{{ 'component-blog.css' | asset_url | stylesheet_tag }}{%- endif -%}
  {%- if request.page_type contains 'customers' or request.page_type == 'customers/account' -%}{{ 'component-customer.css' | asset_url | stylesheet_tag }}{%- endif -%}

  <script>document.documentElement.className = document.documentElement.className.replace('no-js','js');</script>
  <script src="{{ 'global.js' | asset_url }}" defer></script>
  <script src="{{ 'carousel.js' | asset_url }}" defer></script>

  <script src="{{ 'component-header.js' | asset_url }}" defer></script>
</head>

<body class="template-{{ request.page_type | handle }}{% if settings.animations_enabled %} anim-enabled{% endif %}">
  <a class="skip-to-content visually-hidden" href="#MainContent">{{ 'accessibility.skip_to_content' | t }}</a>

  {%- sections 'header-group' -%}

  <main id="MainContent" class="content-for-layout" role="main" tabindex="-1">
    {{ content_for_layout }}
  </main>

  {%- sections 'footer-group' -%}

  {%- render 'cart-drawer' -%}
  {%- render 'search-modal' -%}

  {%- if settings.whatsapp_enabled and settings.whatsapp_number != blank -%}
    <a class="whatsapp-float" href="https://wa.me/{{ settings.whatsapp_number | remove: '+' | remove: ' ' }}{% if settings.whatsapp_message != blank %}?text={{ settings.whatsapp_message | url_encode }}{% endif %}" target="_blank" rel="noopener" aria-label="{{ 'general.social.whatsapp' | t }}">
      {%- render 'icon', name: 'whatsapp', size: 30 -%}
    </a>
  {%- endif -%}

  <ul hidden>
    <li id="a11y-refresh-page-message">{{ 'accessibility.refresh_page' | t }}</li>
  </ul>

  <script>
    window.Shopify = window.Shopify || {};
    window.Shopify.routes = window.Shopify.routes || {};
    window.Shopify.routes.root = "{{ routes.root_url }}";
    window.themeStrings = {
      addToCart: {{ 'products.product.add_to_cart' | t | json }},
      soldOut: {{ 'products.product.sold_out' | t | json }},
      unavailable: {{ 'products.product.unavailable' | t | json }},
      lowStock: {{ 'products.product.low_stock' | t: count: '[count]' | json }}
    };
    window.moneyFormat = {{ shop.money_format | json }};
  </script>
</body>
</html>
