{%- comment -%} Reset password {%- endcomment -%}
<div class="customer customer-reset">
  <div class="container container--text">
    <h1 class="customer__title text-center">{{ 'customer.reset.title' | t }}</h1>
    {%- form 'reset_customer_password' -%}
      {%- if form.errors -%}<div class="contact-form__errors">{{ form.errors | default_errors }}</div>{%- endif -%}
      <div class="contact-form__row"><input type="password" name="customer[password]" placeholder="{{ 'customer.reset.password' | t }}" class="full" required></div>
      <div class="contact-form__row"><input type="password" name="customer[password_confirmation]" placeholder="{{ 'customer.reset.confirm' | t }}" class="full" required></div>
      <button type="submit" class="button">{{ 'customer.reset.submit' | t }}</button>
    {%- endform -%}
  </div>
</div>
