{%- comment -%} Footer — logo, menu columns, newsletter, payment, social, copyright {%- endcomment -%}
{%- style -%}
  #shopify-section-{{ section.id }} { --footer-bg: {{ section.settings.bg | default: settings.color_brand_green }}; --footer-fg: {{ section.settings.text_color | default: '#ffffff' }}; }
{%- endstyle -%}
<footer class="footer" role="contentinfo">
  <div class="footer__inner container">
    {%- for block in section.blocks -%}
      {%- if block.type == 'logo' -%}
        <div class="footer__top" {{ block.shopify_attributes }}>
          {%- assign flogo = block.settings.logo | default: settings.logo_light -%}
          {%- if flogo != blank -%}
            <img class="footer__logo" src="{{ flogo | image_url: width: 500 }}" alt="{{ shop.name }}" width="{{ flogo.width }}" height="{{ flogo.height }}" loading="lazy">
          {%- else -%}
            <img class="footer__logo" src="{{ 'brand_akinna_logo_white.png' | asset_url }}" alt="{{ shop.name }}" width="469" height="94" loading="lazy">
          {%- endif -%}
        </div>
        <div class="footer__divider"></div>
      {%- endif -%}
    {%- endfor -%}
    <div class="footer__grid">
      {%- for block in section.blocks -%}
        {%- case block.type -%}
          {%- when 'menu' -%}
            <div class="footer__col footer__col--menu" {{ block.shopify_attributes }}>
              <details class="footer__details" open>
                <summary class="footer__title">{{ block.settings.title }}{%- render 'icon', name: 'chevron-down', size: 14 -%}</summary>
                {%- if block.settings.menu != blank -%}
                  <ul class="footer__links">
                    {%- for link in linklists[block.settings.menu].links -%}
                      {%- liquid
                        assign is_external = false
                        if link.url contains '://'
                          unless link.url contains shop.domain or link.url contains shop.permanent_domain
                            assign is_external = true
                          endunless
                        endif
                      -%}
                      <li><a href="{{ link.url }}"{% if is_external %} target="_blank" rel="noopener"{% endif %}>{{ link.title }}</a></li>
                    {%- endfor -%}
                  </ul>
                {%- endif -%}
              </details>
            </div>
          {%- when 'newsletter' -%}
            <div class="footer__col footer__col--newsletter" {{ block.shopify_attributes }}>
              {%- if block.settings.heading != blank -%}<h4 class="footer__news-heading">{{ block.settings.heading }}</h4>{%- endif -%}
              {%- if block.settings.text != blank -%}<div class="footer__news-text rte">{{ block.settings.text }}</div>{%- endif -%}
              {%- form 'customer', class: 'footer__subscribe' -%}
                <input type="hidden" name="contact[tags]" value="newsletter">
                {%- if form.posted_successfully? -%}
                  <p class="footer__news-success">{{ 'general.newsletter.success' | t }}</p>
                {%- endif -%}
                <div class="footer__subscribe-row">
                  <input type="email" name="contact[email]" placeholder="{{ 'general.newsletter.label' | t }}" required aria-label="{{ 'general.newsletter.label' | t }}">
                  <button type="submit" aria-label="{{ 'general.newsletter.button' | t }}">{%- render 'icon', name: 'arrow-right', size: 16 -%}</button>
                </div>
              {%- endform -%}
              {%- if block.settings.show_payment -%}
                <div class="footer__payment">
                  <h5 class="footer__payment-title">{{ block.settings.payment_title }}</h5>
                  <div class="footer__payment-icons">
                    {%- for type in shop.enabled_payment_types -%}{{ type | payment_type_svg_tag: class: 'footer__payment-icon' }}{%- endfor -%}
                  </div>
                </div>
              {%- endif -%}
              <div class="footer__social">
                {%- if settings.social_facebook != blank -%}<a href="{{ settings.social_facebook }}" target="_blank" rel="noopener" aria-label="{{ 'general.social.facebook' | t }}">{%- render 'icon', name: 'facebook', size: 20 -%}</a>{%- endif -%}
                {%- if settings.social_instagram != blank -%}<a href="{{ settings.social_instagram }}" target="_blank" rel="noopener" aria-label="{{ 'general.social.instagram' | t }}">{%- render 'icon', name: 'instagram', size: 20 -%}</a>{%- endif -%}
                {%- if settings.social_youtube != blank -%}<a href="{{ settings.social_youtube }}" target="_blank" rel="noopener" aria-label="{{ 'general.social.youtube' | t }}">{%- render 'icon', name: 'youtube', size: 20 -%}</a>{%- endif -%}
              </div>
            </div>
        {%- endcase -%}
      {%- endfor -%}
    </div>

    {% comment %} {%- if section.settings.show_localization -%}
      <div class="footer__localization">{%- render 'localization-form', place: 'footer' -%}</div>
    {%- endif -%} {% endcomment %}

    <div class="footer__bottom">
      <p class="footer__copyright">&copy; {{ 'now' | date: '%Y' }} {{ shop.name }}, {{ section.settings.copyright_text }}</p>
      <a href="#top" class="footer__totop" data-scroll-top>{{ 'general.back_to_top' | t }}</a>
      <p class="footer__credit">
        {{ 'general.credit_by' | t }}
        {%- if section.settings.credit_text != blank -%}
          {%- if section.settings.credit_link != blank -%}
            <a href="{{ section.settings.credit_link }}" target="_blank" rel="noopener">{{ section.settings.credit_text }}</a>
          {%- else -%}
            {{ section.settings.credit_text }}
          {%- endif -%}
        {%- endif -%}
      </p>
      {%- if section.settings.bottom_menu != blank -%}
        <ul class="footer__bottom-links">
          {%- for link in linklists[section.settings.bottom_menu].links -%}<li><a href="{{ link.url }}">{{ link.title }}</a></li>{%- endfor -%}
        </ul>
      {%- endif -%}
    </div>
  </div>
</footer>

{% schema %}
{
  "name": "Footer",
  "settings": [
    {
      "type": "color",
      "id": "bg",
      "label": "Background",
      "default": "#0e3432"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text",
      "default": "#ffffff"
    },
    {
      "type": "text",
      "id": "copyright_text",
      "label": "Copyright suffix",
      "default": "All rights reserved."
    },
    {
      "type": "link_list",
      "id": "bottom_menu",
      "label": "Bottom links menu"
    },
    {
      "type": "text",
      "id": "credit_text",
      "label": "Credit name (bottom bar)",
      "default": "Mark91 Studio"
    },
    {
      "type": "url",
      "id": "credit_link",
      "label": "Credit link"
    },
    {
      "type": "checkbox",
      "id": "show_localization",
      "label": "Show country/currency & language selector",
      "default": true
    }
  ],
  "blocks": [
    {
      "type": "logo",
      "name": "Logo",
      "limit": 1,
      "settings": [
        {
          "type": "image_picker",
          "id": "logo",
          "label": "Footer logo (defaults to light logo)"
        }
      ]
    },
    {
      "type": "menu",
      "name": "Menu column",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Shop"
        },
        {
          "type": "link_list",
          "id": "menu",
          "label": "Menu"
        }
      ]
    },
    {
      "type": "newsletter",
      "name": "Newsletter & social",
      "limit": 1,
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "More akinna this way"
        },
        {
          "type": "richtext",
          "id": "text",
          "label": "Text",
          "default": "<p>Join #AKINNASphere &amp; get 15% off on your second order!</p>"
        },
        {
          "type": "checkbox",
          "id": "show_payment",
          "label": "Show payment icons",
          "default": false
        },
        {
          "type": "text",
          "id": "payment_title",
          "label": "Payment title",
          "default": "Secure online payment"
        }
      ]
    }
  ],
  "default": {
    "blocks": [
      {
        "type": "logo"
      },
      {
        "type": "menu",
        "settings": {
          "title": "Shop By Category"
        }
      },
      {
        "type": "menu",
        "settings": {
          "title": "Customer Services"
        }
      },
      {
        "type": "menu",
        "settings": {
          "title": "About Us"
        }
      },
      {
        "type": "menu",
        "settings": {
          "title": "Legal"
        }
      },
      {
        "type": "newsletter"
      }
    ]
  }
}
{% endschema %}
