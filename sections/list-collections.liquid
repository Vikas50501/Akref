{%- comment -%} All collections grid {%- endcomment -%}
{%- style -%}
  #shopify-section-{{ section.id }} { padding-top: {{ section.settings.padding_top }}px; padding-bottom: {{ section.settings.padding_bottom }}px; --lc-cols: {{ section.settings.columns }}; }
{%- endstyle -%}
<div class="list-collections index-section">
  <div class="container">
    {%- if section.settings.heading != blank -%}<div class="list-collections__head text-center"><h1 class="thb-shop-title">{{ section.settings.heading }}</h1></div>{%- endif -%}
    <div class="list-collections__grid">
      {%- assign colls = collections -%}
      {%- if section.settings.list == 'featured' -%}{%- assign colls = section.settings.featured_collections -%}{%- endif -%}
      {%- for collection in colls -%}
        <a href="{{ collection.url }}" class="collection-card">
          <div class="collection-card__media aspect-ratio" style="--ratio-percent: 125%;">
            {%- if collection.featured_image -%}
              <img src="{{ collection.featured_image | image_url: width: 800 }}" alt="{{ collection.title | escape }}" width="{{ collection.featured_image.width }}" height="{{ collection.featured_image.height }}" loading="lazy">
            {%- else -%}{{ 'collection-1' | placeholder_svg_tag: 'placeholder-svg' }}{%- endif -%}
          </div>
          <h3 class="collection-card__title">{{ collection.title }}</h3>
        </a>
      {%- endfor -%}
    </div>
  </div>
</div>

{% stylesheet %}
.list-collections__head { margin-bottom: 40px; }
.list-collections__grid { display: grid; grid-template-columns: repeat(var(--lc-cols, 3), 1fr); gap: 24px 16px; }
.collection-card__media { background: var(--color-bg-alt); overflow: hidden; }
.collection-card__media img { transition: transform 0.6s var(--easing); }
.collection-card:hover .collection-card__media img { transform: scale(1.05); }
.collection-card__title { font-family: var(--font-heading); font-size: 22px; text-align: center; margin-top: 14px; }
@media (max-width: 1023px) { .list-collections__grid { grid-template-columns: repeat(2, 1fr); } }
@media (max-width: 480px) { .list-collections__grid { grid-template-columns: 1fr; } }
{% endstylesheet %}

{% schema %}
{
  "name": "List collections",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Collections"
    },
    {
      "type": "select",
      "id": "list",
      "label": "Collections to show",
      "options": [
        {
          "value": "all",
          "label": "All"
        },
        {
          "value": "featured",
          "label": "Selected"
        }
      ],
      "default": "all"
    },
    {
      "type": "collection_list",
      "id": "featured_collections",
      "label": "Selected collections"
    },
    {
      "type": "range",
      "id": "columns",
      "label": "Columns",
      "min": 2,
      "max": 4,
      "step": 1,
      "default": 3
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 60
    }
  ]
}
{% endschema %}
