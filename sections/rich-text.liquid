{%- comment -%} Reusable rich-text / heading section {%- endcomment -%}
{%- style -%}
  #shopify-section-{{ section.id }} { padding-top: {{ section.settings.padding_top }}px; padding-bottom: {{ section.settings.padding_bottom }}px; background: {{ section.settings.bg }}; color: {{ section.settings.text_color }}; text-align: {{ section.settings.alignment }}; }
{%- endstyle -%}
<div class="rich-text index-section">
  <div class="container {% if section.settings.width == 'narrow' %}container--text{% elsif section.settings.width == 'medium' %}container--narrow{% endif %}">
    <div class="rich-text__inner" data-anim="up">
      {%- for block in section.blocks -%}
        {%- case block.type -%}
          {%- when 'tagline' -%}<p class="tag-line" {{ block.shopify_attributes }}>{{ block.settings.text }}</p>
          {%- when 'heading' -%}<h2 class="rich-text__heading letters-slide-up text-split" {{ block.shopify_attributes }}>{{ block.settings.text }}</h2>
          {%- when 'text' -%}<div class="rich-text__body rte" {{ block.shopify_attributes }}>{{ block.settings.text }}</div>
          {%- when 'button' -%}<a href="{{ block.settings.link }}" class="button {{ block.settings.style }}" {{ block.shopify_attributes }}>{{ block.settings.label }}</a>
        {%- endcase -%}
      {%- endfor -%}
    </div>
  </div>
</div>
{% stylesheet %}
.rich-text__inner { display: flex; flex-direction: column; gap: 18px; align-items: inherit; }
.rich-text[style*="center"] .rich-text__inner { align-items: center; }
.rich-text__heading { font-size: clamp(26px, 3.4vw, 40px); }
.rich-text__body { max-width: 720px; }
{% endstylesheet %}
{% schema %}
{
  "name": "Rich text",
  "class": "index-section rich-text-section",
  "settings": [
    {
      "type": "select",
      "id": "alignment",
      "label": "Alignment",
      "options": [
        {
          "value": "left",
          "label": "Left"
        },
        {
          "value": "center",
          "label": "Center"
        }
      ],
      "default": "center"
    },
    {
      "type": "select",
      "id": "width",
      "label": "Width",
      "options": [
        {
          "value": "narrow",
          "label": "Narrow"
        },
        {
          "value": "medium",
          "label": "Medium"
        },
        {
          "value": "wide",
          "label": "Wide"
        }
      ],
      "default": "medium"
    },
    {
      "type": "color",
      "id": "bg",
      "label": "Background",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text",
      "default": "#141515"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top",
      "min": 0,
      "max": 140,
      "step": 4,
      "unit": "px",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom",
      "min": 0,
      "max": 140,
      "step": 4,
      "unit": "px",
      "default": 60
    }
  ],
  "blocks": [
    {
      "type": "tagline",
      "name": "Tagline",
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "Text"
        }
      ]
    },
    {
      "type": "heading",
      "name": "Heading",
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "Text",
          "default": "Heading"
        }
      ]
    },
    {
      "type": "text",
      "name": "Text",
      "settings": [
        {
          "type": "richtext",
          "id": "text",
          "label": "Text",
          "default": "<p>Share information about your brand.</p>"
        }
      ]
    },
    {
      "type": "button",
      "name": "Button",
      "settings": [
        {
          "type": "text",
          "id": "label",
          "label": "Label"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        },
        {
          "type": "select",
          "id": "style",
          "label": "Style",
          "options": [
            {
              "value": "",
              "label": "Solid"
            },
            {
              "value": "alt",
              "label": "Outline"
            }
          ],
          "default": ""
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Rich text",
      "blocks": [
        {
          "type": "heading"
        },
        {
          "type": "text"
        }
      ]
    }
  ]
}
{% endschema %}
