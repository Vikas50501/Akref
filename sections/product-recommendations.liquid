{%- comment -%} Related products via Shopify recommendations API {%- endcomment -%}
{%- style -%}
  #shopify-section-{{ section.id }} { padding-top: {{ section.settings.padding_top }}px; padding-bottom: {{ section.settings.padding_bottom }}px; background: {{ section.settings.bg }}; color: {{ section.settings.text_color }}; }
{%- endstyle -%}
{%- if recommendations.performed and recommendations.products_count > 0 -%}
  <div class="recommendations index-section">
    <div class="common-container">
      {%- if section.settings.heading != blank -%}<div class="recommendations__head text-center"><h2 class="letters-slide-up text-split">{{ section.settings.heading }}</h2></div>{%- endif -%}
      <div class="recommendations__grid">
        {%- for product in recommendations.products limit: section.settings.limit -%}
          {%- render 'product-card', product: product -%}
        {%- endfor -%}
      </div>
    </div>
  </div>
{%- elsif recommendations.performed == false -%}
  <product-recommendations class="recommendations index-section" data-url="{{ routes.product_recommendations_url }}?section_id={{ section.id }}&product_id={{ product.id }}&limit={{ section.settings.limit }}">
    <div class="common-container"><div class="recommendations__placeholder"></div></div>
  </product-recommendations>
  <script>
    (function(){
      var el = document.currentScript.previousElementSibling;
      if(!el || !el.dataset.url) return;
      fetch(el.dataset.url).then(function(r){return r.text();}).then(function(html){
        var doc = new DOMParser().parseFromString(html,'text/html');
        var fresh = doc.querySelector('product-recommendations');
        if(fresh) el.innerHTML = fresh.innerHTML;
        if(window.AKINNA){ window.AKINNA.initLazy && window.AKINNA.initLazy(); }
      });
    })();
  </script>
{%- endif -%}

{% stylesheet %}
.recommendations__head { margin-bottom: 40px; }
.recommendations__grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 4px 4px; }
@media (max-width: 1023px) { .recommendations__grid { grid-template-columns: repeat(2, 1fr); gap: 12px; } }
{% endstylesheet %}

{% schema %}
{
  "name": "Product recommendations",
  "class": "index-section recommendations-section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "You may also like"
    },
    {
      "type": "range",
      "id": "limit",
      "label": "Products",
      "min": 2,
      "max": 10,
      "step": 1,
      "default": 4
    },
    {
      "type": "color",
      "id": "bg",
      "label": "Background",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text",
      "default": "#141515"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 60
    }
  ],
  "presets": [
    {
      "name": "Product recommendations"
    }
  ]
}
{% endschema %}
