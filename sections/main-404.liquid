{%- comment -%} 404 page {%- endcomment -%}
<div class="not-found">
  <div class="container text-center">
    <p class="not-found__code">404</p>
    <h1 class="not-found__title">{{ 'general.404.title' | t }}</h1>
    <p class="not-found__text">{{ 'general.404.subtext' | t }}</p>
    <a href="{{ routes.all_products_collection_url }}" class="button">{{ 'general.404.link' | t }}</a>
  </div>
</div>
{% stylesheet %}
.not-found { padding: 100px 0 120px; }
.not-found__code { font-family: var(--font-heading); font-size: clamp(80px, 16vw, 180px); line-height: 1; margin: 0; opacity: 0.15; }
.not-found__title { font-size: clamp(24px, 4vw, 36px); margin: 0 0 12px; }
.not-found__text { opacity: 0.7; margin-bottom: 28px; }
{% endstylesheet %}
{% schema %}
{
  "name": "t:sections.main-404.name"
}
{% endschema %}
