{%- comment -%} Cart page {%- endcomment -%}
{%- style -%}
  #shopify-section-{{ section.id }} { padding-top: {{ section.settings.padding_top }}px; padding-bottom: {{ section.settings.padding_bottom }}px; }
{%- endstyle -%}
<div class="cart-page">
  <div class="container container--narrow">
    <div class="cart-page__head">
      <h1 class="thb-shop-title">{{ 'cart.title' | t }}</h1>
    </div>
    <div class="cart-page__body" data-cart-body>
      {%- render 'cart-contents', context: 'page' -%}
    </div>
  </div>
</div>
{% schema %}
{
  "name": "t:sections.main-cart.name",
  "settings": [
    {
      "type": "range",
      "id": "padding_top",
      "label": "t:sections.main-cart.settings.padding_top.label",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "t:sections.main-cart.settings.padding_bottom.label",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 80
    }
  ]
}
{% endschema %}
