{%- comment -%} Featured product carousel with decorative heading block {%- endcomment -%}
{%- liquid
  assign coll = collections[section.settings.collection]
  assign limit = section.settings.products_limit
-%}
{%- style -%}
  #shopify-section-{{ section.id }} { padding-top: {{ section.settings.padding_top }}px; padding-bottom: {{ section.settings.padding_bottom }}px; background: {{ section.settings.bg }}; color: {{ section.settings.text_color }}; }
{%- endstyle -%}
<div class="product-section index-section">
  <div class="common-container">
    <div class="top-section-wrap" data-anim="up">
      {%- if section.settings.icon != blank -%}<img class="ps-icon" src="{{ section.settings.icon | image_url: width: 100 }}" alt="" width="50" height="50" loading="lazy">{%- endif -%}
      <span class="straight-line"></span>
      {%- if section.settings.show_star -%}{%- render 'icon', name: 'star', size: 22 -%}{%- endif -%}
      {%- if section.settings.tagline != blank -%}<p class="tag-line">{{ section.settings.tagline }}</p>{%- endif -%}
      {%- if section.settings.heading != blank -%}<h2 class="letters-slide-up text-split">{{ section.settings.heading }}</h2>{%- endif -%}
      <div class="dewrap">
        {%- if section.settings.text != blank -%}<div class="ps-desc rte">{{ section.settings.text }}</div>{%- endif -%}
        {%- if section.settings.button_label != blank -%}
          <a href="{{ section.settings.button_link }}" class="button custombtn"><span class="label-text">{{ section.settings.button_label }}</span>{%- render 'icon', name: 'arrow-right', size: 14 -%}</a>
        {%- endif -%}
      </div>
    </div>

    <div class="product-carousel" data-carousel>
      <div class="product-carousel__track" data-carousel-track>
        {%- if coll != blank and coll.products.size > 0 -%}
          {%- for product in coll.products limit: limit -%}
            <div class="product-carousel__slide" data-carousel-slide>{%- render 'product-card', product: product -%}</div>
          {%- endfor -%}
        {%- else -%}
          {%- for i in (1..4) -%}
            <div class="product-carousel__slide" data-carousel-slide>
              <div class="product-card"><figure class="product_thumbnail" style="--ratio-percent:122%;">{{ 'product-1' | placeholder_svg_tag: 'placeholder-svg' }}</figure><div class="product-card__info"><h3 class="product-card__title">Example product</h3><span class="price"><ins><span class="amount">₹ 14,000</span></ins></span></div></div>
            </div>
          {%- endfor -%}
        {%- endif -%}
      </div>
      {%- if section.settings.show_arrows -%}
        <div class="product-carousel__nav">
          <button class="carousel-arrow" data-carousel-prev aria-label="{{ 'accessibility.previous' | t }}">{%- render 'icon', name: 'arrow-left', size: 18 -%}</button>
          <button class="carousel-arrow" data-carousel-next aria-label="{{ 'accessibility.next' | t }}">{%- render 'icon', name: 'arrow-right', size: 18 -%}</button>
        </div>
      {%- endif -%}
    </div>
  </div>
</div>

{% stylesheet %}
.product-section .top-section-wrap { margin-bottom: 40px; }
.ps-icon { width: 50px; height: 50px; object-fit: contain; }
.ps-desc { max-width: 560px; text-align: center; opacity: 0.8; }
.product-carousel { position: relative; }
.product-carousel__track { display: grid; grid-auto-flow: column; grid-auto-columns: calc((100% - 3 * 4px) / 4); gap: 4px; overflow-x: auto; scroll-snap-type: x mandatory; scrollbar-width: none; }
.product-carousel__track::-webkit-scrollbar { display: none; }
.product-carousel__slide { scroll-snap-align: start; }
.product-carousel__nav { display: flex; justify-content: center; gap: 12px; margin-top: 28px; }
.carousel-arrow { width: 42px; height: 42px; border: 1px solid var(--color-border); background: none; border-radius: 50%; cursor: pointer; display: inline-flex; align-items: center; justify-content: center; color: inherit; transition: all var(--transition); }
.carousel-arrow:hover { background: var(--color-green); color: #fff; border-color: var(--color-green); }
.carousel-arrow[disabled] { opacity: 0.3; pointer-events: none; }
@media (max-width: 1023px) { .product-carousel__track { grid-auto-columns: calc((100% - 2 * 4px) / 2.4); } }
@media (max-width: 767px) { .product-carousel__track { grid-auto-columns: 68%; gap: 12px; } }
{% endstylesheet %}

{% schema %}
{
  "name": "t:sections.product-carousel.name",
  "class": "index-section product-section-wrap",
  "settings": [
    {
      "type": "header",
      "content": "t:sections.product-carousel.headers.h0"
    },
    {
      "type": "image_picker",
      "id": "icon",
      "label": "t:sections.product-carousel.settings.icon.label"
    },
    {
      "type": "checkbox",
      "id": "show_star",
      "label": "t:sections.product-carousel.settings.show_star.label",
      "default": true
    },
    {
      "type": "text",
      "id": "tagline",
      "label": "t:sections.product-carousel.settings.tagline.label",
      "default": "Designed by Annika Saraf."
    },
    {
      "type": "text",
      "id": "heading",
      "label": "t:sections.product-carousel.settings.heading.label",
      "default": "Luxury Handbags Made With Finest Indian Leather."
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "t:sections.product-carousel.settings.text.label",
      "default": "<p>Our signature silhouettes balance sculptural design with enduring elegance.</p>"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "t:sections.product-carousel.settings.button_label.label",
      "default": "Discover all"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "t:sections.product-carousel.settings.button_link.label"
    },
    {
      "type": "header",
      "content": "t:sections.product-carousel.headers.h1"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "t:sections.product-carousel.settings.collection.label"
    },
    {
      "type": "range",
      "id": "products_limit",
      "label": "t:sections.product-carousel.settings.products_limit.label",
      "min": 4,
      "max": 16,
      "step": 1,
      "default": 8
    },
    {
      "type": "checkbox",
      "id": "show_arrows",
      "label": "t:sections.product-carousel.settings.show_arrows.label",
      "default": true
    },
    {
      "type": "header",
      "content": "t:sections.product-carousel.headers.h2"
    },
    {
      "type": "color",
      "id": "bg",
      "label": "t:sections.product-carousel.settings.bg.label",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "t:sections.product-carousel.settings.text_color.label",
      "default": "#141515"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "t:sections.product-carousel.settings.padding_top.label",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "t:sections.product-carousel.settings.padding_bottom.label",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "default": 80
    }
  ],
  "presets": [
    {
      "name": "Product carousel"
    }
  ]
}
{% endschema %}
