{%- comment -%}
  Product carousel — decorative heading + a fully-featured slider (loop/rewind,
  autoplay w/ progress bar, drag/swipe, wheel, keyboard, dots, scrollbar, fade/slide).
  Engine: assets/product-carousel.js (a <product-carousel> custom element).
{%- endcomment -%}
{%- liquid
  assign coll = collections[section.settings.collection]
  assign limit = section.settings.products_limit
  assign card_ratio = section.settings.image_ratio | plus: 0
-%}
{%- capture options -%}
  {"perView":{"desktop":{{ section.settings.per_view_desktop }},"tablet":{{ section.settings.per_view_tablet }},"mobile":{{ section.settings.per_view_mobile }}},
  "gap":{"desktop":{{ section.settings.gap_desktop }},"tablet":{{ section.settings.gap_tablet }},"mobile":{{ section.settings.gap_mobile }}},
  "rows":{{ section.settings.rows }},"autoplay":{{ section.settings.autoplay }},"autoplaySpeed":{{ section.settings.autoplay_speed }},
  "speed":{{ section.settings.transition_speed }},"loop":{{ section.settings.loop }},"rewind":{{ section.settings.rewind }},
  "drag":{{ section.settings.drag }},"wheel":{{ section.settings.wheel }},"keyboard":{{ section.settings.keyboard }},
  "hoverPause":{{ section.settings.hover_pause }},"animation":"{{ section.settings.animation_type }}"}
{%- endcapture -%}
{%- style -%}
  #shopify-section-{{ section.id }} {
    padding-top: {{ section.settings.padding_top }}px; padding-bottom: {{ section.settings.padding_bottom }}px;
    margin-top: {{ section.settings.margin_top }}px; margin-bottom: {{ section.settings.margin_bottom }}px;
    background: {{ section.settings.bg }}; color: {{ section.settings.text_color }};
    --pc-card-bg: {{ section.settings.card_bg }}; --pc-card-text: {{ section.settings.card_text_color }};
    --pc-card-radius: {{ section.settings.card_radius }}px;
    --pc-card-shadow: {% if section.settings.card_shadow %}0 8px 24px rgba(0,0,0,0.08){% else %}none{% endif %};
  }
{%- endstyle -%}
<div class="product-section index-section{% if section.settings.section_width == 'full' %} product-section--full{% endif %}{% unless section.settings.show_compare_price %} pc--hide-compare{% endunless %}">
  <div class="{% if section.settings.section_width == 'full' %}product-section__full-pad{% else %}common-container{% endif %}">
    <div class="top-section-wrap text-{{ section.settings.heading_alignment }}" data-anim="up" style="color:{{ section.settings.heading_color }};">
      {%- if section.settings.icon != blank -%}<img class="ps-icon" src="{{ section.settings.icon | image_url: width: 100 }}" alt="" width="50" height="50" loading="lazy">{%- endif -%}
      <span class="straight-line"></span>
      {%- if section.settings.show_star -%}{%- render 'icon', name: 'star', size: 22 -%}{%- endif -%}
      {%- if section.settings.tagline != blank -%}<p class="tag-line">{{ section.settings.tagline }}</p>{%- endif -%}
      {%- if section.settings.heading != blank -%}<h2 class="letters-slide-up text-split" style="font-size:{{ section.settings.heading_size }}px;">{{ section.settings.heading }}</h2>{%- endif -%}
      <div class="dewrap">
        {%- if section.settings.text != blank -%}<div class="ps-desc rte">{{ section.settings.text }}</div>{%- endif -%}
        {%- if section.settings.button_label != blank -%}
          <a href="{{ section.settings.button_link }}" class="{% if section.settings.button_style == 'solid' %}button{% else %}custombtn{% endif %}"><span class="label-text">{{ section.settings.button_label }}</span>{%- render 'icon', name: 'arrow-right', size: 14 -%}</a>
        {%- endif -%}
      </div>
    </div>

    <product-carousel class="pc" data-options='{{ options | strip_newlines | strip }}'>
      <div class="pc__viewport" data-pc-viewport>
        <div class="pc__track" data-pc-track>
          {%- if coll != blank and coll.products.size > 0 -%}
            {%- for product in coll.products limit: limit -%}
              <div class="pc__item pc__item--{{ section.settings.card_style }}" data-pc-slide>
                {%- render 'product-card',
                  product: product,
                  section_id: section.id,
                  card_ratio: card_ratio,
                  show_quick_add: section.settings.show_quick_add,
                  show_vendor: section.settings.show_vendor,
                  show_price: section.settings.show_price,
                  show_badge: section.settings.show_badge,
                  show_rating: section.settings.show_rating,
                  show_wishlist: section.settings.show_wishlist,
                  show_quick_view: section.settings.show_quick_view
                -%}
              </div>
            {%- endfor -%}
          {%- else -%}
            {%- for i in (1..6) -%}
              <div class="pc__item pc__item--{{ section.settings.card_style }}" data-pc-slide>
                <div class="product-card"><figure class="product_thumbnail" style="--ratio-percent:{{ card_ratio | times: 100 }}%;">{{ 'product-1' | placeholder_svg_tag: 'placeholder-svg' }}</figure><div class="product-card__info"><h3 class="product-card__title">Example product</h3><span class="price"><ins><span class="amount">₹ 14,000</span></ins></span></div></div>
              </div>
            {%- endfor -%}
          {%- endif -%}
        </div>
      </div>

      {%- if section.settings.show_progressbar and section.settings.autoplay -%}
        <div class="pc__progress"><span data-pc-progress-fill></span></div>
      {%- endif -%}

      <div class="pc__controls">
        {%- if section.settings.show_arrows -%}
          <button type="button" class="carousel-arrow pc__arrow pc__arrow--prev" data-pc-prev aria-label="{{ 'accessibility.previous' | t }}">{%- render 'icon', name: 'arrow-left', size: 18 -%}</button>
        {%- endif -%}
        {%- if section.settings.show_dots -%}<div class="pc__dots" data-pc-dots></div>{%- endif -%}
        {%- if section.settings.show_arrows -%}
          <button type="button" class="carousel-arrow pc__arrow pc__arrow--next" data-pc-next aria-label="{{ 'accessibility.next' | t }}">{%- render 'icon', name: 'arrow-right', size: 18 -%}</button>
        {%- endif -%}
      </div>

      {%- if section.settings.show_scrollbar -%}
        <div class="pc__scrollbar" data-pc-scrollbar><span class="pc__scrollbar-thumb" data-pc-scrollbar-thumb></span></div>
      {%- endif -%}
    </product-carousel>

    {%- if section.settings.show_quick_view and coll != blank -%}
      {%- for product in coll.products limit: limit -%}
        <dialog class="quickview" id="QuickView-{{ product.id }}-{{ section.id }}">
          <button type="button" class="quickview__close" data-quickview-close aria-label="{{ 'accessibility.close' | t }}">{%- render 'icon', name: 'close', size: 20 -%}</button>
          <div class="quickview__body">
            <div class="quickview__media aspect-ratio" style="--ratio-percent:{{ card_ratio | times: 100 }}%;">
              {%- render 'responsive-image', image: product.featured_media.preview_image, alt: product.title, sizes: '(max-width:767px) 90vw, 400px' -%}
            </div>
            <div class="quickview__info">
              <h3>{{ product.title }}</h3>
              {%- render 'price', product: product -%}
              {%- if product.description != blank -%}<div class="quickview__desc rte">{{ product.description | strip_html | truncatewords: 30 }}</div>{%- endif -%}
              {%- if product.available -%}
                {%- if product.variants.size > 1 -%}
                  <a href="{{ product.url }}" class="button">{{ 'products.card.choose_options' | t }}</a>
                {%- else -%}
                  <product-quick-add><a href="{{ product.url }}" data-id="{{ product.selected_or_first_available_variant.id }}" class="add_to_cart_button product-card--add-to-cart-button-simple button"><span data-add-text>{{ 'products.card.add_to_cart' | t }}</span></a></product-quick-add>
                {%- endif -%}
              {%- else -%}
                <span class="button" style="opacity:.5;pointer-events:none;">{{ 'products.card.sold_out' | t }}</span>
              {%- endif -%}
              <a href="{{ product.url }}" class="custombtn quickview__link"><span>{{ 'products.card.view_full_details' | t }}</span></a>
            </div>
          </div>
        </dialog>
      {%- endfor -%}
    {%- endif -%}
  </div>
</div>
<script src="{{ 'product-carousel.js' | asset_url }}" defer></script>

{% stylesheet %}
.product-section .top-section-wrap { margin-bottom: 40px; }
.product-section__full-pad { padding: 0 var(--container-gutter); }
.ps-icon { width: 50px; height: 50px; object-fit: contain; }
.ps-desc { max-width: 560px; opacity: 0.8; }
.text-left.top-section-wrap { align-items: flex-start; text-align: left; }
.text-right.top-section-wrap { align-items: flex-end; text-align: right; }
.pc--hide-compare .price del { display: none; }
.pc__item--bordered .product-card { border: 1px solid var(--color-border); padding: 8px 8px 14px; }
.pc__item--minimal .product-card__info { padding-left: 0; padding-right: 0; }
.pc__item--minimal .product-card__title { text-transform: none; }

.pc { position: relative; display: block; }
.pc:focus-visible { outline: 2px solid var(--color-focus); outline-offset: 4px; }
.pc__viewport { overflow: hidden; }
.pc__track { display: flex; }
/* justify-content:flex-start keeps a partial page (last page, or a collection with
   fewer products than perView) left-aligned at true card width instead of the
   flex-box spreading its lone item(s) out to fill the row. */
.pc__page { display: flex; flex: 0 0 100%; width: 100%; gap: var(--pc-gap, 4px); justify-content: flex-start; }
.pc__track--fade .pc__page { transition-property: opacity; opacity: 0; }
.pc__track--fade .pc__page.is-active { opacity: 1; }
/* flex-grow:0 is the fix: a slot always holds its computed per-view width and never
   stretches to fill leftover space when a page has fewer items than --pc-pv (e.g. a
   1-product collection, or an underfull final page). */
.pc__slot { flex: 0 0 calc((100% - (var(--pc-pv, 4) - 1) * var(--pc-gap, 4px)) / var(--pc-pv, 4)); min-width: 0; }
.pc__col { display: flex; flex-direction: column; gap: var(--pc-gap, 4px); }
.pc__col > * { flex: 1; }

.pc__controls { display: flex; align-items: center; justify-content: center; gap: 16px; margin-top: 28px; }
.pc__arrow[disabled] { opacity: 0.3; pointer-events: none; }
.pc__dots { display: flex; align-items: center; gap: 8px; }
.pc__dot { width: 8px; height: 8px; border-radius: 50%; border: 0; padding: 0; background: var(--color-border); cursor: pointer; transition: background var(--transition), transform var(--transition); }
.pc__dot.is-active { background: var(--color-green); transform: scale(1.3); }

.pc__progress { height: 2px; background: var(--color-border); margin-top: 20px; overflow: hidden; }
.pc__progress span { display: block; height: 100%; width: 0; background: var(--color-green); }

.pc__scrollbar { position: relative; height: 3px; background: var(--color-border); margin-top: 16px; cursor: pointer; border-radius: 2px; }
.pc__scrollbar-thumb { position: absolute; top: 0; left: 0; height: 100%; background: var(--color-ink); border-radius: 2px; transition: left 0.2s var(--easing); }

@media (max-width: 1023px) { .pc__controls { margin-top: 20px; } }

/* Quick view */
.quickview { border: 0; padding: 0; max-width: 720px; width: 92vw; border-radius: var(--radius); }
.quickview::backdrop { background: rgba(0,0,0,0.5); }
.quickview__close { position: absolute; top: 12px; right: 12px; background: none; border: 0; cursor: pointer; z-index: 2; min-width: 40px; min-height: 40px; }
.quickview__body { display: grid; grid-template-columns: 1fr 1fr; gap: 32px; padding: 32px; }
.quickview__info { display: flex; flex-direction: column; gap: 12px; align-items: flex-start; }
.quickview__desc { opacity: 0.75; font-size: 14px; }
.quickview__link { margin-top: 4px; }
@media (max-width: 640px) { .quickview__body { grid-template-columns: 1fr; padding: 24px; } }
{% endstylesheet %}

{% schema %}
{
  "name": "Product carousel",
  "class": "index-section product-section-wrap",
  "settings": [
    { "type": "header", "content": "Heading block" },
    { "type": "image_picker", "id": "icon", "label": "Decorative icon" },
    { "type": "checkbox", "id": "show_star", "label": "Show star", "default": true },
    { "type": "text", "id": "tagline", "label": "Tagline", "default": "Designed by Annika Saraf." },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Luxury Handbags Made With Finest Indian Leather." },
    { "type": "range", "id": "heading_size", "label": "Heading size", "min": 20, "max": 60, "step": 2, "unit": "px", "default": 32 },
    { "type": "richtext", "id": "text", "label": "Description", "default": "<p>Our signature silhouettes balance sculptural design with enduring elegance.</p>" },
    { "type": "select", "id": "heading_alignment", "label": "Alignment", "options": [{"value":"center","label":"Center"},{"value":"left","label":"Left"},{"value":"right","label":"Right"}], "default": "center" },
    { "type": "color", "id": "heading_color", "label": "Heading/tagline color", "default": "#141515" },
    { "type": "text", "id": "button_label", "label": "Button label", "default": "Discover all" },
    { "type": "url", "id": "button_link", "label": "Button link" },
    { "type": "select", "id": "button_style", "label": "Button style", "options": [{"value":"underline","label":"Underlined text"},{"value":"solid","label":"Solid button"}], "default": "underline" },

    { "type": "header", "content": "Products" },
    { "type": "collection", "id": "collection", "label": "Collection" },
    { "type": "range", "id": "products_limit", "label": "Products to show", "min": 4, "max": 24, "step": 1, "default": 8 },
    { "type": "range", "id": "rows", "label": "Rows", "min": 1, "max": 3, "step": 1, "default": 1 },
    { "type": "range", "id": "per_view_desktop", "label": "Products per view — desktop", "min": 1, "max": 8, "step": 1, "default": 4 },
    { "type": "range", "id": "per_view_tablet", "label": "Products per view — tablet", "min": 1, "max": 5, "step": 1, "default": 3 },
    { "type": "range", "id": "per_view_mobile", "label": "Products per view — mobile", "min": 1, "max": 3, "step": 1, "default": 1 },
    { "type": "range", "id": "gap_desktop", "label": "Gap — desktop", "min": 0, "max": 60, "step": 2, "unit": "px", "default": 4 },
    { "type": "range", "id": "gap_tablet", "label": "Gap — tablet", "min": 0, "max": 60, "step": 2, "unit": "px", "default": 12 },
    { "type": "range", "id": "gap_mobile", "label": "Gap — mobile", "min": 0, "max": 60, "step": 2, "unit": "px", "default": 12 },
    { "type": "select", "id": "section_width", "label": "Section width", "options": [{"value":"contained","label":"Contained"},{"value":"full","label":"Full width"}], "default": "contained" },

    { "type": "header", "content": "Behavior" },
    { "type": "checkbox", "id": "autoplay", "label": "Autoplay", "default": false },
    { "type": "range", "id": "autoplay_speed", "label": "Autoplay speed", "min": 1500, "max": 8000, "step": 500, "unit": "ms", "default": 4000 },
    { "type": "range", "id": "transition_speed", "label": "Transition speed", "min": 200, "max": 1200, "step": 50, "unit": "ms", "default": 500 },
    { "type": "select", "id": "animation_type", "label": "Animation type", "options": [{"value":"slide","label":"Slide"},{"value":"fade","label":"Fade"}], "default": "slide" },
    { "type": "checkbox", "id": "loop", "label": "Infinite loop", "default": false },
    { "type": "checkbox", "id": "rewind", "label": "Rewind to start (if loop is off)", "default": true },
    { "type": "checkbox", "id": "drag", "label": "Drag / swipe", "default": true },
    { "type": "checkbox", "id": "wheel", "label": "Mouse wheel navigation", "default": false },
    { "type": "checkbox", "id": "keyboard", "label": "Keyboard navigation", "default": true },
    { "type": "checkbox", "id": "hover_pause", "label": "Pause autoplay on hover/focus", "default": true },

    { "type": "header", "content": "Navigation controls" },
    { "type": "checkbox", "id": "show_arrows", "label": "Show arrows", "default": true },
    { "type": "checkbox", "id": "show_dots", "label": "Show pagination dots", "default": false },
    { "type": "checkbox", "id": "show_scrollbar", "label": "Show scrollbar", "default": false },
    { "type": "checkbox", "id": "show_progressbar", "label": "Show autoplay progress bar", "default": false },

    { "type": "header", "content": "Card content" },
    { "type": "select", "id": "image_ratio", "label": "Image ratio", "options": [{"value":"0.75","label":"Landscape (4:3)"},{"value":"1","label":"Square (1:1)"},{"value":"1.2195","label":"Portrait (default)"},{"value":"1.3333","label":"Tall (3:4)"}], "default": "1.2195" },
    { "type": "select", "id": "card_style", "label": "Card style", "options": [{"value":"default","label":"Default"},{"value":"bordered","label":"Bordered"},{"value":"minimal","label":"Minimal"}], "default": "default" },
    { "type": "checkbox", "id": "show_vendor", "label": "Show vendor", "default": false },
    { "type": "checkbox", "id": "show_price", "label": "Show price", "default": true },
    { "type": "checkbox", "id": "show_compare_price", "label": "Show compare-at (strikethrough) price", "default": true },
    { "type": "checkbox", "id": "show_badge", "label": "Show sale/sold-out badge", "default": true },
    { "type": "checkbox", "id": "show_rating", "label": "Show rating (if a review app provides reviews.rating)", "default": false },
    { "type": "checkbox", "id": "show_wishlist", "label": "Show wishlist icon", "default": false },
    { "type": "checkbox", "id": "show_quick_add", "label": "Show quick add", "default": true },
    { "type": "checkbox", "id": "show_quick_view", "label": "Show quick view", "default": false },
    { "type": "range", "id": "card_radius", "label": "Card corner radius", "min": 0, "max": 24, "step": 1, "unit": "px", "default": 0 },
    { "type": "checkbox", "id": "card_shadow", "label": "Card shadow", "default": false },
    { "type": "color", "id": "card_bg", "label": "Card background", "default": "#ffffff00" },
    { "type": "color", "id": "card_text_color", "label": "Card text color", "default": "#141515" },

    { "type": "header", "content": "Section style" },
    { "type": "color", "id": "bg", "label": "Background", "default": "#ffffff" },
    { "type": "color", "id": "text_color", "label": "Text", "default": "#141515" },
    { "type": "range", "id": "padding_top", "label": "Padding top", "min": 0, "max": 160, "step": 4, "unit": "px", "default": 80 },
    { "type": "range", "id": "padding_bottom", "label": "Padding bottom", "min": 0, "max": 160, "step": 4, "unit": "px", "default": 80 },
    { "type": "range", "id": "margin_top", "label": "Margin top", "min": 0, "max": 80, "step": 4, "unit": "px", "default": 0 },
    { "type": "range", "id": "margin_bottom", "label": "Margin bottom", "min": 0, "max": 80, "step": 4, "unit": "px", "default": 0 }
  ],
  "presets": [{ "name": "Product carousel" }]
}
{% endschema %}
