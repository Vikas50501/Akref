{%- comment -%}
  About hero — two-column intro: tagline + heading + subheading + body copy on
  one side, a full-height image on the other. On mobile the tagline/heading
  move above the image (matches the original "mobileonly" duplicate block).
{%- endcomment -%}
{%- style -%}
  #shopify-section-{{ section.id }} {
    padding-top: {{ section.settings.padding_top }}px; padding-bottom: {{ section.settings.padding_bottom }}px;
    background: {{ section.settings.bg }}; color: {{ section.settings.text_color }};
    --ah-media-h: {{ section.settings.media_height }}vh;
  }
{%- endstyle -%}
{%- if section.settings.enabled -%}
<div class="about-hero index-section{% if section.settings.image_position == 'left' %} about-hero--reverse{% endif %}">
  <div class="common-container">
    <div class="about-hero__grid">
      <div class="about-hero__text">
        <div class="about-hero__desktop-head">
          {%- if section.settings.tagline != blank -%}<p class="tag-line">{{ section.settings.tagline }}</p>{%- endif -%}
          {%- if section.settings.heading != blank -%}<h1 class="letters-slide-up text-split title" data-anim="up">{{ section.settings.heading }}</h1>{%- endif -%}
        </div>
        {%- if section.settings.subheading != blank -%}<h3 class="letters-slide-up text-split about-hero__sub" data-anim="up">{{ section.settings.subheading }}</h3>{%- endif -%}
        {%- if section.settings.text != blank -%}<div class="about-hero__body rte">{{ section.settings.text }}</div>{%- endif -%}
        {%- if section.settings.button_label != blank -%}
          <a href="{{ section.settings.button_link }}" class="custombtn about-hero__btn"><span>{{ section.settings.button_label }}</span>{%- render 'icon', name: 'arrow-up-right', size: 10 -%}</a>
        {%- endif -%}
      </div>
      <div class="about-hero__media">
        <div class="about-hero__mobile-head">
          {%- if section.settings.tagline != blank -%}<p class="tag-line">{{ section.settings.tagline }}</p>{%- endif -%}
          {%- if section.settings.heading != blank -%}<h1 class="title">{{ section.settings.heading }}</h1>{%- endif -%}
        </div>
        {%- if section.settings.image != blank -%}
          <img class="about-hero__img" gsap-scale-anim src="{{ section.settings.image | image_url: width: 1400 }}" srcset="{{ section.settings.image | image_url: width: 700 }} 700w, {{ section.settings.image | image_url: width: 1100 }} 1100w, {{ section.settings.image | image_url: width: 1600 }} 1600w" sizes="(max-width:1023px) 100vw, 50vw" alt="{{ section.settings.image.alt | escape }}" width="{{ section.settings.image.width }}" height="{{ section.settings.image.height }}" loading="eager" fetchpriority="high">
        {%- else -%}
          {{ 'lifestyle-1' | placeholder_svg_tag: 'placeholder-svg about-hero__img' }}
        {%- endif -%}
      </div>
    </div>
  </div>
</div>
{%- endif -%}

{% stylesheet %}
.about-hero__grid { display: grid; grid-template-columns: 1fr 1fr; align-items: center; justify-items: center; gap: 60px; }
.about-hero--reverse .about-hero__media { order: -1; }
.about-hero__text { display: flex; flex-direction: column; align-items: flex-start; text-align: left; max-width: 600px; }
.about-hero__desktop-head { display: flex; flex-direction: column; align-items: flex-start; text-align: left; }
.about-hero__text .tag-line { margin: 0 0 20px; text-align: left; }
.about-hero__text .title { font-size: 40px; margin-bottom: 12px; }
.about-hero__sub { font-size: 20px; line-height: 120%; font-weight: 400; margin-bottom: 20px; width: 100%; }
.about-hero__body { width: 80%; padding-top: 24px; border-top: 1px solid rgba(var(--color-ink-rgb), 0.1); }
.about-hero__body p { color: rgba(var(--color-ink-rgb), 0.75); margin-bottom: 0; }
.about-hero__btn { margin-top: 20px; }
.about-hero__media { position: relative; width: 100%; height: 100%; }
.about-hero__mobile-head { display: none; }
.about-hero__img { width: 100%; height: var(--ah-media-h, 90vh); object-fit: cover; display: block; }
@media (max-width: 768px) {
  .about-hero__grid { grid-template-columns: 1fr; gap: 24px; }
  .about-hero--reverse .about-hero__media { order: 0; }
  .about-hero__desktop-head { display: none; }
  .about-hero__mobile-head { display: flex; flex-direction: column; margin-bottom: 16px; }
  .about-hero__text { max-width: 100%; }
  .about-hero__body { width: 100%; font-size: 13px; }
  .about-hero__img { height: 60vh; }
}
{% endstylesheet %}

{% schema %}
{
  "name": "About hero",
  "class": "index-section about-hero-section",
  "settings": [
    { "type": "checkbox", "id": "enabled", "label": "Enable section", "default": true },
    { "type": "text", "id": "tagline", "label": "Tagline", "default": "Meet The Founders" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Annika Saraf & Sanchit Goyal" },
    { "type": "text", "id": "subheading", "label": "Subheading", "default": "Two Paths. One Vision." },
    { "type": "richtext", "id": "text", "label": "Body text" },
    { "type": "text", "id": "button_label", "label": "Button label" },
    { "type": "url", "id": "button_link", "label": "Button link" },
    { "type": "image_picker", "id": "image", "label": "Image" },
    { "type": "select", "id": "image_position", "label": "Image position", "options": [{"value":"right","label":"Right"},{"value":"left","label":"Left"}], "default": "right" },
    { "type": "range", "id": "media_height", "label": "Image height", "min": 40, "max": 100, "step": 2, "unit": "vh", "default": 90 },
    { "type": "header", "content": "Style" },
    { "type": "color", "id": "bg", "label": "Background", "default": "#f5f3f5" },
    { "type": "color", "id": "text_color", "label": "Text", "default": "#141515" },
    { "type": "range", "id": "padding_top", "label": "Padding top", "min": 0, "max": 120, "step": 4, "unit": "px", "default": 0 },
    { "type": "range", "id": "padding_bottom", "label": "Padding bottom", "min": 0, "max": 120, "step": 4, "unit": "px", "default": 0 }
  ],
  "presets": [{ "name": "About hero" }]
}
{% endschema %}
