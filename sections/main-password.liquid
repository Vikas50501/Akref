{%- comment -%} Password page {%- endcomment -%}
<div class="password-content">
  <div class="container container--text text-center">
    {%- if section.settings.logo != blank -%}
      <img class="password-logo" src="{{ section.settings.logo | image_url: width: 500 }}" alt="{{ shop.name }}" loading="eager">
    {%- else -%}
      <img class="password-logo" src="{{ 'brand_akinna_logo_black.png' | asset_url }}" alt="{{ shop.name }}" width="469" height="94">
    {%- endif -%}
    {%- if section.settings.heading != blank -%}<h1 class="password-heading">{{ section.settings.heading }}</h1>{%- endif -%}
    {%- if section.settings.text != blank -%}<div class="password-text rte">{{ section.settings.text }}</div>{%- endif -%}

    {%- form 'customer', class: 'password-subscribe' -%}
      {%- if form.posted_successfully? -%}<p class="contact-form__success">{{ 'general.newsletter.success' | t }}</p>{%- endif -%}
      <div class="footer__subscribe-row" style="margin:0 auto;max-width:400px;">
        <input type="email" name="contact[email]" placeholder="{{ 'general.newsletter.label' | t }}" required>
        <button type="submit" aria-label="{{ 'general.newsletter.button' | t }}">{%- render 'icon', name: 'arrow-right', size: 16 -%}</button>
      </div>
    {%- endform -%}

    <div class="password-login">
      <details>
        <summary>Enter using password</summary>
        {%- form 'storefront_password' -%}
          {%- if form.errors -%}<div class="contact-form__errors">{{ form.errors | default_errors }}</div>{%- endif -%}
          <div class="footer__subscribe-row" style="margin:12px auto 0;max-width:400px;">
            <input type="password" name="password" placeholder="Password">
            <button type="submit" aria-label="{{ 'general.password_page.login_button' | t }}">{%- render 'icon', name: 'arrow-right', size: 16 -%}</button>
          </div>
        {%- endform -%}
      </details>
    </div>
  </div>
</div>
{% stylesheet %}
.password-content { min-height: 100vh; display: flex; align-items: center; justify-content: center; padding: 40px 0; }
.password-logo { max-height: 40px; width: auto; margin: 0 auto 32px; }
.password-heading { font-size: clamp(28px, 4vw, 44px); margin-bottom: 16px; }
.password-text { opacity: 0.8; margin-bottom: 28px; }
.password-login { margin-top: 32px; }
.password-login summary { font-family: var(--font-ui); font-size: 12px; text-transform: uppercase; letter-spacing: 0.06em; cursor: pointer; }
{% endstylesheet %}
{% schema %}
{
  "name": "Password",
  "settings": [
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Opening soon"
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Text",
      "default": "<p>Be the first to know when we launch.</p>"
    }
  ]
}
{% endschema %}
