{%- comment -%} Hero slideshow — full-height fading slides with desktop/mobile images {%- endcomment -%}
{%- style -%}
  #shopify-section-{{ section.id }} {
    --slide-dh: {{ section.settings.desktop_height }}vh;
    --slide-mh: {{ section.settings.mobile_height }}vh;
  }
{%- endstyle -%}

<div class="slideshow section-slideshow" data-carousel data-autoplay="{{ section.settings.autoplay | times: 1000 }}" data-fade="true">
  <div class="slideshow__track" data-carousel-track data-fade-track>
    {%- for block in section.blocks -%}
      {%- liquid
        assign overlay = block.settings.overlay_opacity | divided_by: 100.0
        assign pos = block.settings.content_position | default: 'bottom-right'
      -%}
      <div class="slideshow__slide{% if forloop.first %} is-active{% endif %}" data-carousel-slide {{ block.shopify_attributes }} style="--overlay-opacity: {{ overlay }};">
        <div class="slideshow__bg">
          {%- if block.settings.image != blank -%}
            <picture>
              {%- if block.settings.image_mobile != blank -%}
                <source media="(max-width: 767px)" srcset="{{ block.settings.image_mobile | image_url: width: 800 }} 800w, {{ block.settings.image_mobile | image_url: width: 1200 }} 1200w" sizes="100vw">
              {%- endif -%}
              <img class="slideshow-image" src="{{ block.settings.image | image_url: width: 1600 }}" srcset="{{ block.settings.image | image_url: width: 1000 }} 1000w, {{ block.settings.image | image_url: width: 1600 }} 1600w, {{ block.settings.image | image_url: width: 2400 }} 2400w, {{ block.settings.image | image_url: width: 3000 }} 3000w" sizes="100vw" alt="{{ block.settings.heading | escape }}" width="{{ block.settings.image.width }}" height="{{ block.settings.image.height }}" {% if forloop.first %}loading="eager" fetchpriority="high"{% else %}loading="lazy"{% endif %}>
            </picture>
          {%- else -%}
            <div class="slideshow__placeholder">{{ 'lifestyle-1' | placeholder_svg_tag: 'placeholder-svg' }}</div>
          {%- endif -%}
          <span class="slideshow__overlay"></span>
        </div>
        <div class="slideshow__inner content-{{ pos }}">
          <div class="slideshow__content" data-anim="up">
            {%- if block.settings.subheading != blank -%}<p class="slideshow__subheading tag-line">{{ block.settings.subheading }}</p>{%- endif -%}
            {%- if block.settings.heading != blank -%}{%- if forloop.first -%}<h1 class="slideshow__heading">{{ block.settings.heading }}</h1>{%- else -%}<p class="slideshow__heading" role="heading" aria-level="2">{{ block.settings.heading }}</p>{%- endif -%}{%- endif -%}
            {%- if block.settings.text != blank -%}<div class="slideshow__text">{{ block.settings.text }}</div>{%- endif -%}
            {%- if block.settings.button_label != blank -%}
              <a href="{{ block.settings.button_link }}" class="custombtn slideshow__btn">{{ block.settings.button_label }}{%- render 'icon', name: 'arrow-right', size: 13 -%}</a>
            {%- endif -%}
          </div>
        </div>
      </div>
    {%- endfor -%}
  </div>
  {%- if section.settings.show_dots and section.blocks.size > 1 -%}
    <div class="slideshow__dots" data-slideshow-dots>
      {%- for block in section.blocks -%}<button class="slideshow__dot{% if forloop.first %} is-active{% endif %}" data-slide-to="{{ forloop.index0 }}" aria-label="Slide {{ forloop.index }}"></button>{%- endfor -%}
    </div>
  {%- endif -%}
</div>

{%- if section.blocks.size > 1 -%}
<script>
  (function(){
    var root = document.getElementById('shopify-section-{{ section.id }}').querySelector('.slideshow');
    var slides = root.querySelectorAll('[data-carousel-slide]');
    var dots = root.querySelectorAll('[data-slide-to]');
    var i = 0, n = slides.length, ms = {{ section.settings.autoplay | times: 1000 }};
    function show(k){ slides[i].classList.remove('is-active'); if(dots[i])dots[i].classList.remove('is-active'); i=(k+n)%n; slides[i].classList.add('is-active'); if(dots[i])dots[i].classList.add('is-active'); }
    dots.forEach(function(d){ d.addEventListener('click',function(){ show(parseInt(d.getAttribute('data-slide-to'),10)); }); });
    var reduce = window.matchMedia && window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    var timer = null;
    function start(){ if(ms>0 && !reduce && !timer) timer = setInterval(function(){ if(!document.hidden) show(i+1); }, ms); }
    function stop(){ if(timer){ clearInterval(timer); timer = null; } }
    root.addEventListener('pointerenter', stop); root.addEventListener('pointerleave', start);
    root.addEventListener('focusin', stop); root.addEventListener('focusout', start);
    start();
  })();
</script>
{%- endif -%}

{% stylesheet %}
.section-slideshow { position: relative; }
.slideshow__track { position: relative; }
.slideshow__slide { position: absolute; inset: 0; opacity: 0; transition: opacity 1s ease; pointer-events: none; }
.slideshow__slide.is-active { position: relative; opacity: 1; pointer-events: auto; }
.slideshow__slide:not(.is-active) { visibility: hidden; }
.slideshow__slide.is-active { visibility: visible; }
.slideshow__bg { position: absolute; inset: 0; overflow: hidden; }
.slideshow__slide { height: var(--slide-dh, 92vh); min-height: 520px; }
.slideshow__slide { height: var(--slide-dh, 92vh); height: min(var(--slide-dh, 92vh), 100dvh); }
.slideshow__bg picture { display: block; width: 100%; height: 100%; }
.slideshow-image, .slideshow__placeholder { width: 100%; height: 100%; object-fit: cover; }
.slideshow__overlay { position: absolute; inset: 0; background: linear-gradient(180deg, rgba(0,0,0,calc(var(--overlay-opacity)*0.3)), rgba(0,0,0,var(--overlay-opacity))); }
.slideshow__inner { position: absolute; inset: 0; display: flex; padding: 40px 32px; }
.content-bottom-right { align-items: flex-end; justify-content: flex-end; text-align: left; }
.content-bottom-left { align-items: flex-end; justify-content: flex-start; text-align: left; }
.content-bottom-center { align-items: flex-end; justify-content: center; text-align: center; }
.content-center { align-items: center; justify-content: center; text-align: center; }
.slideshow__content { max-width: 600px; color: #fff; }
.slideshow__subheading { color: #fff; opacity: 0.85; margin-bottom: 12px; }
.slideshow__heading { color: #fff; font-size: clamp(30px, 4vw, 52px); margin-bottom: 14px; text-transform: capitalize; }
.slideshow__text { font-family: var(--font-body); font-size: 16px; margin-bottom: 18px; color: #fff; opacity: 0.92; }
.slideshow__btn { color: #fff; }
.slideshow__btn:hover { color: #fff; }
.slideshow__dots { position: absolute; bottom: 24px; left: 0; right: 0; display: flex; justify-content: center; gap: 8px; z-index: 3; }
.slideshow__dot { width: 44px; height: 44px; padding: 0; border: 0; background: transparent; cursor: pointer; display: inline-flex; align-items: center; justify-content: center; }
.slideshow__dot::before { content: ""; width: 8px; height: 8px; border-radius: 50%; border: 1px solid rgba(255,255,255,0.7); background: transparent; transition: background .2s; }
.slideshow__dot.is-active::before { background: #fff; }
@media (max-width: 767px) {
  .slideshow__slide { height: var(--slide-mh, 90vh); height: min(var(--slide-mh, 90vh), 100dvh); }
  .slideshow__inner { padding: 28px 20px; }
  .content-bottom-right, .content-bottom-left { justify-content: center; text-align: center; }
}
{% endstylesheet %}

{% schema %}
{
  "name": "t:sections.hero-slideshow.name",
  "class": "section-slideshow-wrap",
  "max_blocks": 6,
  "settings": [
    {
      "type": "range",
      "id": "desktop_height",
      "label": "t:sections.hero-slideshow.settings.desktop_height.label",
      "min": 50,
      "max": 100,
      "step": 1,
      "unit": "vh",
      "default": 92
    },
    {
      "type": "range",
      "id": "mobile_height",
      "label": "t:sections.hero-slideshow.settings.mobile_height.label",
      "min": 50,
      "max": 100,
      "step": 1,
      "unit": "vh",
      "default": 90
    },
    {
      "type": "range",
      "id": "autoplay",
      "label": "t:sections.hero-slideshow.settings.autoplay.label",
      "min": 0,
      "max": 10,
      "step": 1,
      "unit": "s",
      "default": 5
    },
    {
      "type": "checkbox",
      "id": "show_dots",
      "label": "t:sections.hero-slideshow.settings.show_dots.label",
      "default": false
    }
  ],
  "blocks": [
    {
      "type": "slide",
      "name": "t:sections.hero-slideshow.blocks.slide.name",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "t:sections.hero-slideshow.blocks.slide.settings.image.label"
        },
        {
          "type": "image_picker",
          "id": "image_mobile",
          "label": "t:sections.hero-slideshow.blocks.slide.settings.image_mobile.label"
        },
        {
          "type": "range",
          "id": "overlay_opacity",
          "label": "t:sections.hero-slideshow.blocks.slide.settings.overlay_opacity.label",
          "min": 0,
          "max": 80,
          "step": 5,
          "unit": "%",
          "default": 40
        },
        {
          "type": "select",
          "id": "content_position",
          "label": "t:sections.hero-slideshow.blocks.slide.settings.content_position.label",
          "options": [
            {
              "value": "bottom-right",
              "label": "t:sections.hero-slideshow.blocks.slide.settings.content_position.options.o0"
            },
            {
              "value": "bottom-left",
              "label": "t:sections.hero-slideshow.blocks.slide.settings.content_position.options.o1"
            },
            {
              "value": "bottom-center",
              "label": "t:sections.hero-slideshow.blocks.slide.settings.content_position.options.o2"
            },
            {
              "value": "center",
              "label": "t:sections.hero-slideshow.blocks.slide.settings.content_position.options.o3"
            }
          ],
          "default": "bottom-right"
        },
        {
          "type": "text",
          "id": "subheading",
          "label": "t:sections.hero-slideshow.blocks.slide.settings.subheading.label"
        },
        {
          "type": "text",
          "id": "heading",
          "label": "t:sections.hero-slideshow.blocks.slide.settings.heading.label",
          "default": "Doppio"
        },
        {
          "type": "richtext",
          "id": "text",
          "label": "t:sections.hero-slideshow.blocks.slide.settings.text.label",
          "default": "<p>Inspired by the rhythm of city life, where elegance and energy coexist.</p>"
        },
        {
          "type": "text",
          "id": "button_label",
          "label": "t:sections.hero-slideshow.blocks.slide.settings.button_label.label",
          "default": "Explore Now"
        },
        {
          "type": "url",
          "id": "button_link",
          "label": "t:sections.hero-slideshow.blocks.slide.settings.button_link.label"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Hero slideshow",
      "blocks": [
        {
          "type": "slide"
        }
      ]
    }
  ]
}
{% endschema %}
