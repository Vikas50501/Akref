{%- comment -%} Media carousel — labelled image/video slides (Elements of AKINNA, features).
  Videos always autoplay muted/looped with no play/pause control. {%- endcomment -%}
{%- liquid
  assign autoplay_ms = 0
  if section.settings.autoplay
    assign autoplay_ms = section.settings.autoplay_speed
  endif
-%}
{%- style -%}
  #shopify-section-{{ section.id }} {
    padding-top: {{ section.settings.padding_top }}px; padding-bottom: {{ section.settings.padding_bottom }}px;
    margin-top: {{ section.settings.margin_top }}px; margin-bottom: {{ section.settings.margin_bottom }}px;
    background: {{ section.settings.bg }}; color: {{ section.settings.text_color }};
    --mc-per: {{ section.settings.per_view_desktop }}; --mc-per-tablet: {{ section.settings.per_view_tablet }}; --mc-per-mobile: {{ section.settings.per_view_mobile }};
    --mc-gap: {{ section.settings.gap_desktop }}px; --mc-gap-mobile: {{ section.settings.gap_mobile }}px;
    --mc-ar: {{ section.settings.aspect }};
    --mc-radius: {{ section.settings.card_radius }}px;
    --mc-shadow: {% if section.settings.card_shadow %}0 8px 24px rgba(0,0,0,0.08){% else %}none{% endif %};
    --mc-card-bg: {{ section.settings.card_bg }};
    --mc-label-color: {{ section.settings.label_color }};
    --mc-label-size: {{ section.settings.label_size }}px;
  }
{%- endstyle -%}
<div class="media-carousel elements-section index-section">
  <div class="common-container">
    {%- if section.settings.heading != blank -%}
      <div class="media-carousel__head text-{{ section.settings.heading_alignment }}" data-anim="up" style="color:{{ section.settings.heading_color }};">
        {%- if section.settings.tagline != blank -%}<div class="tag-line" style="color:{{ section.settings.tagline_color }};">{{ section.settings.tagline }}</div>{%- endif -%}
        <h2 class="letters-slide-up text-split" data-anim="up" style="font-size:{{ section.settings.heading_size }}px;">{{ section.settings.heading }}</h2>
      </div>
    {%- endif -%}
    <div class="media-carousel__wrap" data-carousel {% if autoplay_ms > 0 %}data-autoplay="{{ autoplay_ms }}"{% endif %}>
      <div class="media-carousel__track" data-carousel-track>
        {%- for block in section.blocks -%}
          <div class="media-carousel__slide element-slide" data-carousel-slide {{ block.shopify_attributes }}>
            <div class="element-wrap">
              {%- if block.type == 'video' -%}
                <div class="vd-wrp">
                  {%- if block.settings.video != blank -%}{{ block.settings.video | video_tag: image_size: '600x', loop: true, muted: true, controls: false, autoplay: true, playsinline: true, class: 'fr-video', preload: 'auto' }}
                  {%- elsif block.settings.video_url != blank -%}<video class="fr-video" autoplay loop muted playsinline preload="auto" {% if block.settings.poster %}poster="{{ block.settings.poster | image_url: width: 600 }}"{% endif %}><source src="{{ block.settings.video_url }}" type="video/mp4"></video>{%- endif -%}
                </div>
              {%- else -%}
                {%- if block.settings.image != blank -%}<img class="element-grid-image" src="{{ block.settings.image | image_url: width: 700 }}" alt="{{ block.settings.label | escape }}" width="{{ block.settings.image.width }}" height="{{ block.settings.image.height }}" loading="lazy">
                {%- else -%}{{ 'product-2' | placeholder_svg_tag: 'placeholder-svg element-grid-image' }}{%- endif -%}
              {%- endif -%}
            </div>
            {%- if block.settings.label != blank -%}<p class="elememt-name">{{ block.settings.label }}</p>{%- endif -%}
          </div>
        {%- endfor -%}
      </div>
      {%- if section.settings.show_nav or section.settings.show_pagination -%}
        <div class="media-carousel__nav navigation-wrapper">
          {%- if section.settings.show_nav -%}<button class="carousel-arrow" data-carousel-prev aria-label="{{ 'accessibility.previous' | t }}">{%- render 'icon', name: 'arrow-left', size: 18 -%}</button>{%- endif -%}
          {%- if section.settings.show_pagination -%}<span class="features-pagination" data-carousel-pagination></span>{%- endif -%}
          {%- if section.settings.show_nav -%}<button class="carousel-arrow" data-carousel-next aria-label="{{ 'accessibility.next' | t }}">{%- render 'icon', name: 'arrow-right', size: 18 -%}</button>{%- endif -%}
        </div>
      {%- endif -%}
    </div>
  </div>
</div>

{% stylesheet %}
.media-carousel__head { text-align: center; margin-bottom: 32px; }
.media-carousel__head .tag-line { margin-bottom: 8px; }
.media-carousel__track { display: grid; grid-auto-flow: column; grid-auto-columns: calc((100% - (var(--mc-per) - 1) * var(--mc-gap, 4px)) / var(--mc-per)); gap: var(--mc-gap, 4px); overflow-x: auto; scroll-snap-type: x mandatory; scrollbar-width: none; }
.media-carousel__track::-webkit-scrollbar { display: none; }
.media-carousel__slide { scroll-snap-align: start; }
.element-wrap { position: relative; aspect-ratio: var(--mc-ar, 0.66); overflow: hidden; background: var(--mc-card-bg, var(--color-bg-alt)); border-radius: var(--mc-radius, 0); box-shadow: var(--mc-shadow, none); }
.element-grid-image, .element-wrap video, .element-wrap .fr-video { width: 100%; height: 100%; object-fit: cover; }
.elememt-name { font-family: var(--font-ui); font-size: var(--mc-label-size, 13px); text-transform: uppercase; letter-spacing: 0.03em; margin-top: 12px; text-align: center; color: var(--mc-label-color, inherit); }
.media-carousel__nav { display: flex; align-items: center; justify-content: center; gap: 14px; margin-top: 28px; }
.features-pagination { font-family: var(--font-ui); font-size: 14px; min-width: 60px; text-align: center; }
@media (max-width: 1023px) { .media-carousel__track { grid-auto-columns: calc((100% - (var(--mc-per-tablet) - 1) * var(--mc-gap, 4px)) / var(--mc-per-tablet)); } }
@media (max-width: 767px) { .media-carousel__track { grid-auto-columns: calc((100% - (var(--mc-per-mobile) - 1) * var(--mc-gap-mobile, 12px)) / var(--mc-per-mobile)); gap: var(--mc-gap-mobile, 12px); } }
{% endstylesheet %}

{% schema %}
{
  "name": "Media carousel",
  "class": "index-section media-carousel-section",
  "settings": [
    { "type": "header", "content": "Heading block" },
    { "type": "text", "id": "tagline", "label": "Tagline", "default": "Top features" },
    { "type": "color", "id": "tagline_color", "label": "Tagline color", "default": "#141515" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Elements Of AKINNA" },
    { "type": "range", "id": "heading_size", "label": "Heading size", "min": 20, "max": 60, "step": 2, "unit": "px", "default": 32 },
    { "type": "color", "id": "heading_color", "label": "Heading color", "default": "#141515" },
    { "type": "select", "id": "heading_alignment", "label": "Heading alignment", "options": [{"value":"center","label":"Center"},{"value":"left","label":"Left"},{"value":"right","label":"Right"}], "default": "center" },

    { "type": "header", "content": "Layout" },
    { "type": "range", "id": "per_view_desktop", "label": "Slides per view — desktop", "min": 2, "max": 6, "step": 1, "default": 4 },
    { "type": "range", "id": "per_view_tablet", "label": "Slides per view — tablet", "min": 1, "max": 4, "step": 1, "default": 2 },
    { "type": "range", "id": "per_view_mobile", "label": "Slides per view — mobile", "min": 1, "max": 3, "step": 1, "default": 1 },
    { "type": "range", "id": "gap_desktop", "label": "Gap — desktop", "min": 0, "max": 60, "step": 2, "unit": "px", "default": 4 },
    { "type": "range", "id": "gap_mobile", "label": "Gap — mobile", "min": 0, "max": 60, "step": 2, "unit": "px", "default": 12 },
    { "type": "text", "id": "aspect", "label": "Slide aspect ratio", "default": "0.66", "info": "width/height, e.g. 0.66 = tall" },

    { "type": "header", "content": "Behavior" },
    { "type": "checkbox", "id": "autoplay", "label": "Autoplay carousel", "default": false },
    { "type": "range", "id": "autoplay_speed", "label": "Autoplay speed", "min": 1500, "max": 8000, "step": 500, "unit": "ms", "default": 4000 },
    { "type": "checkbox", "id": "show_nav", "label": "Show arrows", "default": true },
    { "type": "checkbox", "id": "show_pagination", "label": "Show pagination counter", "default": true },

    { "type": "header", "content": "Card style" },
    { "type": "range", "id": "card_radius", "label": "Corner radius", "min": 0, "max": 24, "step": 1, "unit": "px", "default": 0 },
    { "type": "checkbox", "id": "card_shadow", "label": "Card shadow", "default": false },
    { "type": "color", "id": "card_bg", "label": "Card background", "default": "#f5f3f5" },
    { "type": "color", "id": "label_color", "label": "Label color", "default": "#141515" },
    { "type": "range", "id": "label_size", "label": "Label size", "min": 10, "max": 20, "step": 1, "unit": "px", "default": 13 },

    { "type": "header", "content": "Section style" },
    { "type": "color", "id": "bg", "label": "Background", "default": "#ffffff" },
    { "type": "color", "id": "text_color", "label": "Text", "default": "#141515" },
    { "type": "range", "id": "padding_top", "label": "Padding top", "min": 0, "max": 120, "step": 4, "unit": "px", "default": 60 },
    { "type": "range", "id": "padding_bottom", "label": "Padding bottom", "min": 0, "max": 120, "step": 4, "unit": "px", "default": 60 },
    { "type": "range", "id": "margin_top", "label": "Margin top", "min": 0, "max": 80, "step": 4, "unit": "px", "default": 0 },
    { "type": "range", "id": "margin_bottom", "label": "Margin bottom", "min": 0, "max": 80, "step": 4, "unit": "px", "default": 0 }
  ],
  "blocks": [
    {
      "type": "image",
      "name": "Image slide",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Image" },
        { "type": "text", "id": "label", "label": "Label" }
      ]
    },
    {
      "type": "video",
      "name": "Video slide",
      "settings": [
        { "type": "video", "id": "video", "label": "Video" },
        { "type": "video_url", "id": "video_url", "label": "Video URL", "accept": ["youtube", "vimeo"] },
        { "type": "image_picker", "id": "poster", "label": "Poster" },
        { "type": "text", "id": "label", "label": "Label" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Media carousel",
      "blocks": [
        { "type": "image", "settings": { "label": "AKINNA Logo Hardware" } },
        { "type": "image", "settings": { "label": "Green Interiors" } },
        { "type": "image", "settings": { "label": "LWG Certification" } },
        { "type": "image", "settings": { "label": "Signature Panelling" } }
      ]
    }
  ]
}
{% endschema %}
