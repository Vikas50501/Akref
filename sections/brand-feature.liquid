{%- comment -%}
  Brand feature (Akinna Green) — full-bleed image on one side, heading + nested
  image + descriptive text on the other. Dark background by default.
{%- endcomment -%}
{%- style -%}
  #shopify-section-{{ section.id }} {
    padding-top: {{ section.settings.padding_top }}px; padding-bottom: {{ section.settings.padding_bottom }}px;
    background: {{ section.settings.bg }}; color: {{ section.settings.text_color }};
    --bf-h: {{ section.settings.media_height }}vh;
  }
{%- endstyle -%}
<div class="brand-feature index-section">
  <div class="greens-container{% if section.settings.image_position == 'right' %} brand-feature--reverse{% endif %}">
    <div class="left-blocks brand-feature__media">
      {%- if section.settings.image != blank -%}
        <img class="frame-img" gsap-scale-anim src="{{ section.settings.image | image_url: width: 1400 }}" srcset="{{ section.settings.image | image_url: width: 800 }} 800w, {{ section.settings.image | image_url: width: 1400 }} 1400w" sizes="(max-width:1023px) 100vw, 50vw" alt="{{ section.settings.image.alt | escape }}" width="{{ section.settings.image.width }}" height="{{ section.settings.image.height }}" loading="lazy">
      {%- else -%}{{ 'lifestyle-1' | placeholder_svg_tag: 'placeholder-svg frame-img' }}{%- endif -%}
    </div>
    <div class="right-block brand-feature__content">
      <div class="flex-right">
        {%- if section.settings.tagline != blank -%}<p class="tag-line" style="color: {{ section.settings.text_color }};">{{ section.settings.tagline }}</p>{%- endif -%}
        {%- if section.settings.heading != blank -%}<h2 class="letters-slide-up text-split brand-feature__heading">{{ section.settings.heading }}</h2>{%- endif -%}
      </div>
      <div class="rihg-bitim">
        {%- if section.settings.inset_image != blank -%}
          <div class="righti"><img src="{{ section.settings.inset_image | image_url: width: 700 }}" alt="{{ section.settings.inset_image.alt | escape }}" width="{{ section.settings.inset_image.width }}" height="{{ section.settings.inset_image.height }}" loading="lazy"></div>
        {%- endif -%}
        <div class="rightri">
          {%- if section.settings.text != blank -%}<div class="tag-info rte">{{ section.settings.text }}</div>{%- endif -%}
          {%- if section.settings.button_label != blank -%}<a href="{{ section.settings.button_link }}" class="button {{ section.settings.button_style }}" style="margin-top:20px;">{{ section.settings.button_label }}</a>{%- endif -%}
        </div>
      </div>
    </div>
  </div>
</div>

{% stylesheet %}
.brand-feature__media { min-height: var(--bf-h, 80vh); }
.brand-feature--reverse .brand-feature__media { order: 2; }
.brand-feature__content { padding: 70px; display: flex; flex-direction: column; }
.flex-right { display: flex; flex-direction: column; align-items: flex-start; gap: 8px; padding-bottom: 40px; border-bottom: 1px solid rgba(255,255,255,0.1); }
.brand-feature__heading { margin: 0; }
.rihg-bitim { display: grid; grid-template-columns: 0.75fr 1fr; gap: 60px; align-items: start; padding-top: 40px; }
.righti img { width: 100%; height: auto; object-fit: cover; }
.rightri { display: flex; flex-direction: column; align-items: flex-start; }
.brand-feature__content .tag-info { max-width: none; }
@media (max-width: 1023px) {
  .brand-feature--reverse .brand-feature__media { order: 0; }
  .brand-feature__media { min-height: 60vh; }
  .brand-feature__content { padding: 40px 20px; }
  .rihg-bitim { grid-template-columns: 1fr; gap: 24px; }
  .flex-right { padding-bottom: 24px; }
  /* Original hides the inset image below the desktop breakpoint. */
  .righti { display: none; }
}
{% endstylesheet %}

{% schema %}
{
  "name": "Brand feature",
  "class": "index-section brand-feature-section",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Main image"
    },
    {
      "type": "image_picker",
      "id": "inset_image",
      "label": "Inset image (product detail)"
    },
    {
      "type": "select",
      "id": "image_position",
      "label": "Main image position",
      "options": [
        {
          "value": "left",
          "label": "Left"
        },
        {
          "value": "right",
          "label": "Right"
        }
      ],
      "default": "right"
    },
    {
      "type": "range",
      "id": "media_height",
      "label": "Main image height",
      "min": 40,
      "max": 100,
      "step": 2,
      "unit": "vh",
      "default": 80
    },
    {
      "type": "text",
      "id": "tagline",
      "label": "Tagline",
      "default": "The Colour of the Maison."
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "AKINNA Green"
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Text",
      "default": "<p>AKINNA Green is more than a signature — it is our seal. A deep emerald that lives within our packaging, our linings, and our quietest details.</p>"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    },
    {
      "type": "select",
      "id": "button_style",
      "label": "Button style",
      "options": [
        {
          "value": "",
          "label": "Solid"
        },
        {
          "value": "alt",
          "label": "Outline"
        }
      ],
      "default": "alt"
    },
    {
      "type": "header",
      "content": "Style"
    },
    {
      "type": "color",
      "id": "bg",
      "label": "Background",
      "default": "#0e3432"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top",
      "min": 0,
      "max": 120,
      "step": 2,
      "unit": "px",
      "default": 10
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom",
      "min": 0,
      "max": 120,
      "step": 2,
      "unit": "px",
      "default": 10
    }
  ],
  "presets": [
    {
      "name": "Brand feature"
    }
  ]
}
{% endschema %}
