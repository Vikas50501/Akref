{%- comment -%} Contact form with optional info column {%- endcomment -%}
{%- style -%}
  #shopify-section-{{ section.id }} { padding-top: {{ section.settings.padding_top }}px; padding-bottom: {{ section.settings.padding_bottom }}px; }
{%- endstyle -%}
<div class="contact-section index-section">
  <div class="container container--narrow">
    <div class="contact-grid{% unless section.settings.show_info %} contact-grid--single{% endunless %}">
      {%- if section.settings.show_info -%}
        <div class="contact-info">
          {%- if section.settings.heading != blank -%}<h2>{{ section.settings.heading }}</h2>{%- endif -%}
          {%- if section.settings.text != blank -%}<div class="rte">{{ section.settings.text }}</div>{%- endif -%}
          {%- if section.settings.email != blank -%}<p class="contact-info__line"><a href="mailto:{{ section.settings.email }}">{{ section.settings.email }}</a></p>{%- endif -%}
          {%- if section.settings.phone != blank -%}<p class="contact-info__line"><a href="tel:{{ section.settings.phone | remove: ' ' }}">{{ section.settings.phone }}</a></p>{%- endif -%}
          {%- if section.settings.address != blank -%}<div class="contact-info__address rte">{{ section.settings.address }}</div>{%- endif -%}
        </div>
      {%- endif -%}
      <div class="contact-form-wrap">
        {%- form 'contact', id: 'contact_form', class: 'contact-form' -%}
          {%- if form.posted_successfully? -%}
            <p class="contact-form__success" role="status" tabindex="-1">{{ 'contact.form.success' | t }}</p>
          {%- elsif form.errors -%}
            <div class="contact-form__errors" role="alert" tabindex="-1">{{ form.errors | default_errors }}</div>
          {%- endif -%}
          <div class="contact-form__row">
            <label class="visually-hidden" for="ContactFormName">{{ 'contact.form.name' | t }}</label>
            <input type="text" id="ContactFormName" name="contact[name]" class="full" placeholder="{{ 'contact.form.name' | t }}" value="{{ form.name }}" autocomplete="name" required>
          </div>
          <div class="contact-form__row">
            <label class="visually-hidden" for="ContactFormEmail">{{ 'contact.form.email' | t }}</label>
            <input type="email" id="ContactFormEmail" name="contact[email]" class="full" placeholder="{{ 'contact.form.email' | t }}" value="{{ form.email }}" autocomplete="email" required>
          </div>
          <div class="contact-form__row">
            <label class="visually-hidden" for="ContactFormPhone">{{ 'contact.form.phone' | t }}</label>
            <input type="tel" id="ContactFormPhone" name="contact[phone]" class="full" placeholder="{{ 'contact.form.phone' | t }}" value="{{ form.phone }}" autocomplete="tel">
          </div>
          <div class="contact-form__row">
            <label class="visually-hidden" for="ContactFormMessage">{{ 'contact.form.message' | t }}</label>
            <textarea id="ContactFormMessage" name="contact[body]" class="full" rows="8" placeholder="{{ 'contact.form.message' | t }}" required>{{ form.body }}</textarea>
          </div>
          <button type="submit" class="button">{{ 'contact.form.send' | t }}</button>
        {%- endform -%}
      </div>
    </div>
  </div>
</div>

{% stylesheet %}
.contact-grid { display: grid; grid-template-columns: 0.8fr 1.2fr; gap: 48px; align-items: start; }
.contact-grid--single { grid-template-columns: 1fr; max-width: 640px; margin: 0 auto; }
.contact-info h2 { margin-bottom: 16px; }
.contact-info__line a { text-decoration: underline; }
.contact-info__address { margin-top: 16px; opacity: 0.8; }
.contact-form__row { margin-bottom: 16px; }
.contact-form .full { width: 100%; border: 1px solid var(--color-border); border-radius: var(--radius); padding: 14px 16px; font-family: var(--font-body); font-size: 15px; background: var(--color-bg); }
.contact-form textarea { resize: vertical; }
.contact-form__success { padding: 14px 16px; background: rgba(var(--color-green-rgb),0.08); border: 1px solid var(--color-green); border-radius: var(--radius); margin-bottom: 20px; }
.contact-form__errors { color: var(--color-error); margin-bottom: 20px; }
@media (max-width: 767px) { .contact-grid { grid-template-columns: 1fr; gap: 32px; } }
{% endstylesheet %}

{% schema %}
{
  "name": "t:sections.contact-form.name",
  "class": "index-section contact-form-section",
  "settings": [
    {
      "type": "checkbox",
      "id": "show_info",
      "label": "t:sections.contact-form.settings.show_info.label",
      "default": true
    },
    {
      "type": "text",
      "id": "heading",
      "label": "t:sections.contact-form.settings.heading.label",
      "default": "Get in touch"
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "t:sections.contact-form.settings.text.label",
      "default": "<p>We'd love to hear from you.</p>"
    },
    {
      "type": "text",
      "id": "email",
      "label": "t:sections.contact-form.settings.email.label"
    },
    {
      "type": "text",
      "id": "phone",
      "label": "t:sections.contact-form.settings.phone.label"
    },
    {
      "type": "richtext",
      "id": "address",
      "label": "t:sections.contact-form.settings.address.label"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "t:sections.contact-form.settings.padding_top.label",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "t:sections.contact-form.settings.padding_bottom.label",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 60
    }
  ],
  "presets": [
    {
      "name": "Contact form"
    }
  ]
}
{% endschema %}
