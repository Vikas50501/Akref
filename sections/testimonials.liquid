{%- comment -%} Media testimonials carousel (image / video UGC slides) {%- endcomment -%}
{%- style -%}
  #shopify-section-{{ section.id }} { padding-top: {{ section.settings.padding_top }}px; padding-bottom: {{ section.settings.padding_bottom }}px; background: {{ section.settings.bg }}; color: {{ section.settings.text_color }}; }
{%- endstyle -%}
<div class="testimonials happy_customer_home index-section">
  <div class="common-container">
    {%- if section.settings.heading != blank -%}
      <div class="testimonials__head" data-anim="up">
        {%- if section.settings.tagline != blank -%}<p class="tag-line">{{ section.settings.tagline }}</p>{%- endif -%}
        <h2 class="letters-slide-up text-split">{{ section.settings.heading }}</h2>
      </div>
    {%- endif -%}
    <div class="testimonials__carousel" data-carousel>
      <div class="testimonials__track happy-wrapper" data-carousel-track>
        {%- for block in section.blocks -%}
          <div class="testimonials__slide happy-slide" data-carousel-slide {{ block.shopify_attributes }}>
            {%- if block.type == 'video' -%}
              <div class="vd-wrp">
                {%- if block.settings.video != blank -%}
                  {{ block.settings.video | video_tag: image_size: '600x', loop: true, muted: true, controls: false, autoplay: false, playsinline: true, class: 'fr-video', preload: 'metadata' }}
                {%- elsif block.settings.video_url != blank -%}
                  <video class="fr-video" loop muted playsinline preload="metadata" {% if block.settings.poster %}poster="{{ block.settings.poster | image_url: width: 600 }}"{% endif %}><source src="{{ block.settings.video_url }}" type="video/mp4"></video>
                {%- endif -%}
                <button class="play-pause-wrap" data-testi-toggle aria-label="Play"><span class="vd-btn is-play">{%- render 'icon', name: 'play', size: 16 -%}</span><span class="vd-btn is-pause" hidden>{%- render 'icon', name: 'pause', size: 16 -%}</span></button>
              </div>
            {%- else -%}
              {%- if block.settings.image != blank -%}
                <img class="fr-image" src="{{ block.settings.image | image_url: width: 700 }}" alt="{{ block.settings.image.alt | escape }}" width="{{ block.settings.image.width }}" height="{{ block.settings.image.height }}" loading="lazy">
              {%- else -%}{{ 'product-3' | placeholder_svg_tag: 'placeholder-svg fr-image' }}{%- endif -%}
            {%- endif -%}
          </div>
        {%- endfor -%}
      </div>
      <div class="happy-wrapper-navigation">
        <button class="carousel-arrow" data-carousel-prev aria-label="{{ 'accessibility.previous' | t }}">{%- render 'icon', name: 'arrow-left', size: 18 -%}</button>
        <span class="happy-pagination" data-carousel-pagination></span>
        <button class="carousel-arrow" data-carousel-next aria-label="{{ 'accessibility.next' | t }}">{%- render 'icon', name: 'arrow-right', size: 18 -%}</button>
      </div>
    </div>
  </div>
</div>

<script>
  (function(){
    document.getElementById('shopify-section-{{ section.id }}').querySelectorAll('[data-testi-toggle]').forEach(function(btn){
      var vid = btn.parentElement.querySelector('video');
      if(!vid) return;
      btn.addEventListener('click', function(){
        if(vid.paused){ vid.play(); btn.querySelector('.is-play').hidden=true; btn.querySelector('.is-pause').hidden=false; }
        else { vid.pause(); btn.querySelector('.is-play').hidden=false; btn.querySelector('.is-pause').hidden=true; }
      });
    });
  })();
</script>

{% stylesheet %}
.testimonials__head { text-align: center; margin-bottom: 32px; }
.testimonials__track { display: grid; grid-auto-flow: column; grid-auto-columns: 250px; gap: 4px; overflow-x: auto; scroll-snap-type: x mandatory; scrollbar-width: none; }
.testimonials__track::-webkit-scrollbar { display: none; }
.testimonials__slide { scroll-snap-align: start; aspect-ratio: 3/5; position: relative; overflow: hidden; background: var(--color-bg-alt); }
.testimonials__slide .fr-image, .testimonials__slide video, .testimonials__slide .fr-video { width: 100%; height: 100%; object-fit: cover; }
.vd-wrp { position: relative; width: 100%; height: 100%; }
.play-pause-wrap { position: absolute; inset: 0; display: flex; align-items: center; justify-content: center; background: none; border: 0; cursor: pointer; color: #fff; }
.vd-btn { width: 46px; height: 46px; border-radius: 50%; background: rgba(0,0,0,0.35); display: inline-flex; align-items: center; justify-content: center; }
.happy-wrapper-navigation { display: flex; align-items: center; justify-content: center; gap: 14px; margin-top: 24px; }
.happy-pagination { font-family: var(--font-ui); font-size: 14px; text-transform: uppercase; letter-spacing: 0.04em; min-width: 60px; text-align: center; }
{% endstylesheet %}

{% schema %}
{
  "name": "t:sections.testimonials.name",
  "class": "index-section testimonials-section",
  "settings": [
    {
      "type": "text",
      "id": "tagline",
      "label": "t:sections.testimonials.settings.tagline.label"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "t:sections.testimonials.settings.heading.label",
      "default": "Happy Customers"
    },
    {
      "type": "color",
      "id": "bg",
      "label": "t:sections.testimonials.settings.bg.label",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "t:sections.testimonials.settings.text_color.label",
      "default": "#000000"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "t:sections.testimonials.settings.padding_top.label",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "t:sections.testimonials.settings.padding_bottom.label",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 60
    }
  ],
  "blocks": [
    {
      "type": "image",
      "name": "t:sections.testimonials.blocks.image.name",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "t:sections.testimonials.blocks.image.settings.image.label"
        }
      ]
    },
    {
      "type": "video",
      "name": "t:sections.testimonials.blocks.video.name",
      "settings": [
        {
          "type": "video",
          "id": "video",
          "label": "t:sections.testimonials.blocks.video.settings.video.label"
        },
        {
          "type": "video_url",
          "id": "video_url",
          "label": "t:sections.testimonials.blocks.video.settings.video_url.label",
          "accept": [
            "youtube",
            "vimeo"
          ]
        },
        {
          "type": "image_picker",
          "id": "poster",
          "label": "t:sections.testimonials.blocks.video.settings.poster.label"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Testimonials media",
      "blocks": [
        {
          "type": "video"
        },
        {
          "type": "image"
        },
        {
          "type": "image"
        },
        {
          "type": "video"
        }
      ]
    }
  ]
}
{% endschema %}
