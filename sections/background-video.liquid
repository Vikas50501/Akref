{%- comment -%} Full-width background video banner with overlay text {%- endcomment -%}
{%- style -%}
  #shopify-section-{{ section.id }} {
    --bv-dh: {{ section.settings.desktop_height }}px; --bv-mh: {{ section.settings.mobile_height }}px;
    --bv-overlay: {{ section.settings.overlay_opacity | divided_by: 100.0 }};
  }
{%- endstyle -%}
<div class="background-video{% if section.settings.full_width %} background-video--full{% endif %}">
  <div class="background-video__media">
    {%- if section.settings.video != blank -%}
      {{ section.settings.video | video_tag: image_size: '1600x', autoplay: true, loop: true, muted: true, controls: false, class: 'background-video__el', preload: 'metadata' }}
    {%- elsif section.settings.video_url != blank -%}
      <video class="background-video__el" playsinline autoplay loop muted preload="metadata" {% if section.settings.poster %}poster="{{ section.settings.poster | image_url: width: 1600 }}"{% endif %}>
        <source src="{{ section.settings.video_url }}" type="video/mp4">
      </video>
    {%- elsif section.settings.poster != blank -%}
      <img class="background-video__el" src="{{ section.settings.poster | image_url: width: 1600 }}" alt="" loading="lazy">
    {%- else -%}
      <div class="background-video__el placeholder-image">{{ 'lifestyle-1' | placeholder_svg_tag: 'placeholder-svg' }}</div>
    {%- endif -%}
    <span class="background-video__overlay" style="opacity: var(--bv-overlay);"></span>
  </div>
  <div class="background-video__content-wrap">
    <div class="background-video__content" data-anim="up">
      {%- if section.settings.subheading != blank -%}<p class="subheading tag-line">{{ section.settings.subheading }}</p>{%- endif -%}
      {%- if section.settings.heading != blank -%}<h2 class="letters-slide-up text-split background-video__heading">{{ section.settings.heading }}</h2>{%- endif -%}
      {%- if section.settings.text != blank -%}<div class="background-video__text rte">{{ section.settings.text }}</div>{%- endif -%}
      {%- if section.settings.button_label != blank -%}<a href="{{ section.settings.button_link }}" class="custombtn background-video__btn">{{ section.settings.button_label }}{%- render 'icon', name: 'arrow-right', size: 13 -%}</a>{%- endif -%}
    </div>
  </div>
  {%- if section.settings.show_controls -%}
    <button class="background-video__controls" data-video-toggle aria-label="Play/Pause">
      <span class="is-play">{%- render 'icon', name: 'pause', size: 14 -%}</span>
      <span class="is-pause" hidden>{%- render 'icon', name: 'play', size: 14 -%}</span>
    </button>
  {%- endif -%}
</div>

<script>
  (function(){
    var root = document.getElementById('shopify-section-{{ section.id }}');
    var btn = root.querySelector('[data-video-toggle]');
    var vid = root.querySelector('video');
    if(btn && vid){ btn.addEventListener('click', function(){
      if(vid.paused){ vid.play(); btn.querySelector('.is-play').hidden=false; btn.querySelector('.is-pause').hidden=true; }
      else { vid.pause(); btn.querySelector('.is-play').hidden=true; btn.querySelector('.is-pause').hidden=false; }
    }); }
  })();
</script>

{% stylesheet %}
.background-video { position: relative; height: var(--bv-dh, 650px); overflow: hidden; }
.background-video--full { margin: 0; }
.background-video__media { position: absolute; inset: 0; }
.background-video__el { width: 100%; height: 100%; object-fit: cover; }
.background-video__overlay { position: absolute; inset: 0; background: #000; }
.background-video__content-wrap { position: relative; z-index: 2; height: 100%; display: flex; align-items: center; justify-content: center; text-align: center; padding: 20px; }
.background-video__content { max-width: 720px; color: #fff; }
.background-video__content .subheading { color: #fff; opacity: 0.85; margin-bottom: 12px; }
.background-video__heading { color: #fff; font-size: clamp(28px, 4vw, 52px); margin-bottom: 16px; }
.background-video__text { color: #fff; opacity: 0.9; font-size: 15px; }
.background-video__btn { color: #fff; margin-top: 18px; }
.background-video__controls { position: absolute; right: 20px; bottom: 20px; z-index: 3; width: 40px; height: 40px; border-radius: 50%; border: 1px solid rgba(255,255,255,0.5); background: rgba(0,0,0,0.25); color: #fff; cursor: pointer; display: inline-flex; align-items: center; justify-content: center; }
@media (max-width: 767px) { .background-video { height: var(--bv-mh, 500px); } }
{% endstylesheet %}

{% schema %}
{
  "name": "Background video",
  "class": "index-section background-video-section",
  "settings": [
    {
      "type": "video",
      "id": "video",
      "label": "Video (Shopify-hosted)"
    },
    {
      "type": "video_url",
      "id": "video_url",
      "label": "External video URL (mp4)",
      "accept": [
        "youtube",
        "vimeo"
      ]
    },
    {
      "type": "image_picker",
      "id": "poster",
      "label": "Poster / fallback image"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "label": "Overlay opacity",
      "min": 0,
      "max": 80,
      "step": 5,
      "unit": "%",
      "default": 25
    },
    {
      "type": "checkbox",
      "id": "full_width",
      "label": "Full width",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_controls",
      "label": "Show play/pause",
      "default": true
    },
    {
      "type": "range",
      "id": "desktop_height",
      "label": "Desktop height",
      "min": 300,
      "max": 900,
      "step": 10,
      "unit": "px",
      "default": 650
    },
    {
      "type": "range",
      "id": "mobile_height",
      "label": "Mobile height",
      "min": 300,
      "max": 700,
      "step": 10,
      "unit": "px",
      "default": 500
    },
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Inside the Atelier"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Where Craft Becomes Form."
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Text",
      "default": "<p>Every AKINNA piece is brought to life by master artisans in India.</p>"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    }
  ],
  "presets": [
    {
      "name": "Background video"
    }
  ]
}
{% endschema %}
