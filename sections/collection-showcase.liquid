{%- comment -%}
  Collection showcase — centered heading over a lifestyle image, then a product grid.
{%- endcomment -%}
{%- liquid
  assign coll = collections[section.settings.collection]
  assign limit = section.settings.products_limit
-%}
{%- style -%}
  #shopify-section-{{ section.id }} {
    padding-top: {{ section.settings.padding_top }}px; padding-bottom: {{ section.settings.padding_bottom }}px;
    background: {{ section.settings.bg }}; color: {{ section.settings.text_color }};
    --cs-lifestyle-h: {{ section.settings.lifestyle_height }}vh;
  }
{%- endstyle -%}
<div class="collection-showcase explore-collection-section index-section">
  <div class="common-container">
    <div class="collection-showcase__grid">
      <div class="collection-showcase__lifestyle">
        <div class="lifestyle-topwrap">
          {%- if section.settings.image != blank -%}
            <img class="lifestyle-img" gsap-scale-anim src="{{ section.settings.image | image_url: width: 1600 }}" srcset="{{ section.settings.image | image_url: width: 800 }} 800w, {{ section.settings.image | image_url: width: 1600 }} 1600w" sizes="100vw" alt="{{ section.settings.image.alt | escape }}" width="{{ section.settings.image.width }}" height="{{ section.settings.image.height }}" loading="lazy">
          {%- else -%}{{ 'lifestyle-2' | placeholder_svg_tag: 'placeholder-svg lifestyle-img' }}{%- endif -%}
        </div>
        <div class="explore-block-itle" data-anim="up">
          {%- if section.settings.tagline != blank -%}<p class="tag-line">{{ section.settings.tagline }}</p>{%- endif -%}
          {%- if section.settings.heading != blank -%}<h2 class="letters-slide-up text-split">{{ section.settings.heading }}</h2>{%- endif -%}
          {%- if section.settings.button_label != blank -%}<a href="{{ section.settings.button_link }}" class="custombtn"><span>{{ section.settings.button_label }}</span>{%- render 'icon', name: 'arrow-up-right', size: 10 -%}</a>{%- endif -%}
        </div>
      </div>
      <div class="collection-showcase__products">
        {%- if coll != blank and coll.products.size > 0 -%}
          {%- for product in coll.products limit: limit -%}
            {%- render 'product-card', product: product -%}
          {%- endfor -%}
        {%- else -%}
          {%- for i in (1..4) -%}
            <div class="product-card"><figure class="product_thumbnail" style="--ratio-percent:122%;">{{ 'product-2' | placeholder_svg_tag: 'placeholder-svg' }}</figure><div class="product-card__info"><h3 class="product-card__title">Example product</h3><span class="price"><ins><span class="amount">₹ 19,800</span></ins></span></div></div>
          {%- endfor -%}
        {%- endif -%}
      </div>
    </div>
  </div>
</div>

{% stylesheet %}
.collection-showcase__lifestyle { position: relative; margin-bottom: 24px; }
.lifestyle-topwrap { position: relative; height: var(--cs-lifestyle-h, 90vh); overflow: hidden; }
.lifestyle-img { width: 100%; height: 100%; object-fit: cover; }
/* Mobile-first: title is an absolute overlay with a gradient scrim over the image. */
.explore-block-itle { position: absolute; inset: 0; display: flex; flex-direction: column; align-items: center; justify-content: center; text-align: center; gap: 10px; color: #fff; padding: 24px; }
.explore-block-itle::before { content: ''; position: absolute; inset: 0; background: linear-gradient(180deg, rgba(0,0,0,0) 40%, rgba(0,0,0,0.45) 100%); }
.explore-block-itle > * { position: relative; z-index: 1; }
.collection-showcase__products { display: grid; grid-template-columns: repeat(4, 1fr); gap: 24px 4px; }
@media (max-width: 1023px) { .collection-showcase__products { grid-template-columns: repeat(2, 1fr); gap: 12px; } }
@media (max-width: 767px) { .lifestyle-topwrap { height: 60vh; } }
/* Desktop: image + title as two 50% columns; title on section bg, dark text, no scrim. */
@media (min-width: 1024px) {
  .collection-showcase__lifestyle { display: grid; grid-template-columns: 1fr 1fr; align-items: stretch; }
  .lifestyle-topwrap { order: 2; height: var(--cs-lifestyle-h, 90vh); }
  .explore-block-itle { order: 1; position: relative; inset: auto; color: inherit; padding: 40px; }
  .explore-block-itle::before { display: none; }
}
{% endstylesheet %}

{% schema %}
{
  "name": "Collection showcase",
  "class": "index-section collection-showcase-section",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Lifestyle image"
    },
    {
      "type": "range",
      "id": "lifestyle_height",
      "label": "Lifestyle height",
      "min": 40,
      "max": 100,
      "step": 2,
      "unit": "vh",
      "default": 90
    },
    {
      "type": "text",
      "id": "tagline",
      "label": "Tagline"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "New Arrivals"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "Explore all"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection"
    },
    {
      "type": "range",
      "id": "products_limit",
      "label": "Products to show",
      "min": 2,
      "max": 12,
      "step": 1,
      "default": 4
    },
    {
      "type": "header",
      "content": "Style"
    },
    {
      "type": "color",
      "id": "bg",
      "label": "Background",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text",
      "default": "#000000"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top",
      "min": 0,
      "max": 120,
      "step": 2,
      "unit": "px",
      "default": 12
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom",
      "min": 0,
      "max": 120,
      "step": 2,
      "unit": "px",
      "default": 12
    }
  ],
  "presets": [
    {
      "name": "Collection showcase"
    }
  ]
}
{% endschema %}
