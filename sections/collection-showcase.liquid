{%- comment -%}
  Collection showcase — centered heading over a lifestyle image, then a product grid.
{%- endcomment -%}
{%- liquid
  assign coll = collections[section.settings.collection]
  assign limit = section.settings.products_limit
-%}
{%- style -%}
  #shopify-section-{{ section.id }} {
    padding-top: {{ section.settings.padding_top }}px; padding-bottom: {{ section.settings.padding_bottom }}px;
    background: {{ section.settings.bg }}; color: {{ section.settings.text_color }};
    --cs-lifestyle-h: {{ section.settings.lifestyle_height }}vh;
  }
{%- endstyle -%}
<div class="collection-showcase explore-collection-section index-section">
  <div class="common-container">
    <div class="collection-showcase__grid">
      <div class="collection-showcase__lifestyle">
        <div class="lifestyle-topwrap">
          {%- if section.settings.image != blank -%}
            <img class="lifestyle-img" gsap-scale-anim src="{{ section.settings.image | image_url: width: 1600 }}" srcset="{{ section.settings.image | image_url: width: 800 }} 800w, {{ section.settings.image | image_url: width: 1600 }} 1600w" sizes="100vw" alt="{{ section.settings.image.alt | escape }}" width="{{ section.settings.image.width }}" height="{{ section.settings.image.height }}" loading="lazy">
          {%- else -%}{{ 'lifestyle-2' | placeholder_svg_tag: 'placeholder-svg lifestyle-img' }}{%- endif -%}
        </div>
        <div class="explore-block-itle" data-anim="up">
          {%- if section.settings.tagline != blank -%}<p class="tag-line" style="color:#fff;">{{ section.settings.tagline }}</p>{%- endif -%}
          {%- if section.settings.heading != blank -%}<h2 class="letters-slide-up text-split" style="color:#fff;">{{ section.settings.heading }}</h2>{%- endif -%}
          {%- if section.settings.button_label != blank -%}<a href="{{ section.settings.button_link }}" class="custombtn" style="color:#fff;">{{ section.settings.button_label }}{%- render 'icon', name: 'arrow-right', size: 13 -%}</a>{%- endif -%}
        </div>
      </div>
      <div class="collection-showcase__products">
        {%- if coll != blank and coll.products.size > 0 -%}
          {%- for product in coll.products limit: limit -%}
            {%- render 'product-card', product: product -%}
          {%- endfor -%}
        {%- else -%}
          {%- for i in (1..4) -%}
            <div class="product-card"><figure class="product_thumbnail" style="--ratio-percent:122%;">{{ 'product-2' | placeholder_svg_tag: 'placeholder-svg' }}</figure><div class="product-card__info"><h3 class="product-card__title">Example product</h3><span class="price"><ins><span class="amount">₹ 19,800</span></ins></span></div></div>
          {%- endfor -%}
        {%- endif -%}
      </div>
    </div>
  </div>
</div>

{% stylesheet %}
.collection-showcase__lifestyle { position: relative; margin-bottom: 24px; }
.lifestyle-topwrap { position: relative; height: var(--cs-lifestyle-h, 80vh); overflow: hidden; }
.lifestyle-img { width: 100%; height: 100%; object-fit: cover; }
.explore-block-itle { position: absolute; inset: 0; display: flex; flex-direction: column; align-items: center; justify-content: center; text-align: center; gap: 10px; }
.explore-block-itle::before { content: ''; position: absolute; inset: 0; background: rgba(0,0,0,0.25); }
.explore-block-itle > * { position: relative; z-index: 1; }
.collection-showcase__products { display: grid; grid-template-columns: repeat(4, 1fr); gap: 4px 4px; }
@media (max-width: 1023px) { .collection-showcase__products { grid-template-columns: repeat(2, 1fr); gap: 12px; } }
@media (max-width: 767px) { .lifestyle-topwrap { height: 60vh; } }
{% endstylesheet %}

{% schema %}
{
  "name": "t:sections.collection-showcase.name",
  "class": "index-section collection-showcase-section",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "t:sections.collection-showcase.settings.image.label"
    },
    {
      "type": "range",
      "id": "lifestyle_height",
      "label": "t:sections.collection-showcase.settings.lifestyle_height.label",
      "min": 40,
      "max": 100,
      "step": 2,
      "unit": "vh",
      "default": 80
    },
    {
      "type": "text",
      "id": "tagline",
      "label": "t:sections.collection-showcase.settings.tagline.label"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "t:sections.collection-showcase.settings.heading.label",
      "default": "New Arrivals"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "t:sections.collection-showcase.settings.button_label.label",
      "default": "Explore all"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "t:sections.collection-showcase.settings.button_link.label"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "t:sections.collection-showcase.settings.collection.label"
    },
    {
      "type": "range",
      "id": "products_limit",
      "label": "t:sections.collection-showcase.settings.products_limit.label",
      "min": 2,
      "max": 12,
      "step": 1,
      "default": 4
    },
    {
      "type": "header",
      "content": "t:sections.collection-showcase.headers.h0"
    },
    {
      "type": "color",
      "id": "bg",
      "label": "t:sections.collection-showcase.settings.bg.label",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "t:sections.collection-showcase.settings.text_color.label",
      "default": "#000000"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "t:sections.collection-showcase.settings.padding_top.label",
      "min": 0,
      "max": 120,
      "step": 2,
      "unit": "px",
      "default": 12
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "t:sections.collection-showcase.settings.padding_bottom.label",
      "min": 0,
      "max": 120,
      "step": 2,
      "unit": "px",
      "default": 12
    }
  ],
  "presets": [
    {
      "name": "Collection showcase"
    }
  ]
}
{% endschema %}
