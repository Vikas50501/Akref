{%- comment -%} Announcement bar — rotating messages, dismissible {%- endcomment -%}
{%- style -%}
  #shopify-section-{{ section.id }} { --ann-bg: {{ section.settings.bg | default: settings.color_announcement_bg }}; --ann-fg: {{ section.settings.text_color | default: settings.color_announcement_text }}; }
{%- endstyle -%}
<div class="announcement-bar{% if section.settings.dismissible %} is-dismissible{% endif %}" data-announcement>
  <div class="announcement-bar__inner">
    {%- if section.blocks.size > 1 -%}
      <button class="announcement-bar__nav announcement-bar__prev" data-ann-prev aria-label="{{ 'accessibility.previous' | t }}">{%- render 'icon', name: 'chevron-right', size: 14 -%}</button>
    {%- endif -%}
    <div class="announcement-bar__track" data-ann-track>
      {%- for block in section.blocks -%}
        <div class="announcement-bar__item{% if forloop.first %} is-active{% endif %}" data-ann-item {{ block.shopify_attributes }}>
          {%- if block.settings.link != blank -%}<a href="{{ block.settings.link }}">{%- endif -%}
            <span>{{ block.settings.text }}</span>
          {%- if block.settings.link != blank -%}</a>{%- endif -%}
        </div>
      {%- endfor -%}
    </div>
    {%- if section.blocks.size > 1 -%}
      <button class="announcement-bar__nav announcement-bar__next" data-ann-next aria-label="{{ 'accessibility.next' | t }}">{%- render 'icon', name: 'chevron-right', size: 14 -%}</button>
    {%- endif -%}
  </div>
  {%- if section.settings.dismissible -%}
    <button class="announcement-bar__close" data-ann-close aria-label="{{ 'accessibility.close' | t }}">{%- render 'icon', name: 'close', size: 14 -%}</button>
  {%- endif -%}
</div>

<script>
  (function(){
    var bar = document.currentScript.previousElementSibling;
    var items = bar.querySelectorAll('[data-ann-item]');
    var i = 0, n = items.length, auto = {{ section.settings.autorotate | default: 4 | times: 1000 }};
    function show(k){ items[i].classList.remove('is-active'); i=(k+n)%n; items[i].classList.add('is-active'); }
    var nx = bar.querySelector('[data-ann-next]'), pv = bar.querySelector('[data-ann-prev]');
    if(nx) nx.addEventListener('click',function(){show(i+1);});
    if(pv) pv.addEventListener('click',function(){show(i-1);});
    if(n>1 && auto>0) setInterval(function(){ if(!document.hidden) show(i+1); }, auto);
    var cl = bar.querySelector('[data-ann-close]');
    if(cl) cl.addEventListener('click',function(){ bar.style.display='none'; try{sessionStorage.setItem('ann_dismissed','1');}catch(e){} });
    try{ if(sessionStorage.getItem('ann_dismissed')) bar.style.display='none'; }catch(e){}
  })();
</script>

{% stylesheet %}
.announcement-bar {
  position: relative;
  z-index: 6;
  background: var(--ann-bg, #0e3432);
  color: var(--ann-fg, #ffffff);
  font-family: var(--font-ui);
  font-size: 12px;
  letter-spacing: 0.04em;
  text-transform: uppercase;
  min-height: 40px;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 9px 44px;
}
.announcement-bar a { color: inherit; text-decoration: none; }
.announcement-bar a:hover {
  color: inherit;
  text-decoration: none;
}
.announcement-bar__inner {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 14px;
  width: 100%;
  max-width: var(--container-max, 1720px);
}
.announcement-bar__track { position: relative; flex: 1; text-align: center; overflow: hidden; }
.announcement-bar__item { display: none; }
.announcement-bar__item.is-active { display: block; animation: ann-fade 0.4s ease; }
@keyframes ann-fade { from { opacity: 0; } to { opacity: 1; } }
.announcement-bar__nav {
  flex: 0 0 auto;
  background: none; border: 0; padding: 0; cursor: pointer; color: inherit;
  display: inline-flex; align-items: center; justify-content: center;
  width: 28px; height: 28px; opacity: 0.75; transition: opacity var(--transition);
}
.announcement-bar__nav:hover { opacity: 1; }
.announcement-bar__prev { transform: rotate(180deg); }
.announcement-bar__close {
  position: absolute; right: 8px; top: 50%; transform: translateY(-50%);
  background: none; border: 0; padding: 0; cursor: pointer; color: inherit;
  display: inline-flex; align-items: center; justify-content: center;
  width: 40px; height: 40px; opacity: 0.7; transition: opacity var(--transition);
}
.announcement-bar__close:hover { opacity: 1; }
@media (max-width: 767px) {
  .announcement-bar { font-size: 11px; padding: 8px 40px; }
  .announcement-bar__inner { gap: 8px; }
}
{% endstylesheet %}

{% schema %}
{
  "name": "Announcement bar",
  "class": "announcement-section",
  "settings": [
    {
      "type": "color",
      "id": "bg",
      "label": "Background",
      "default": "#0e3432"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "autorotate",
      "label": "Auto-rotate every",
      "min": 0,
      "max": 10,
      "step": 1,
      "unit": "s",
      "default": 4
    },
    {
      "type": "checkbox",
      "id": "dismissible",
      "label": "Allow dismiss",
      "default": false
    }
  ],
  "blocks": [
    {
      "type": "message",
      "name": "Message",
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "Text",
          "default": "Welcome Offer - Get 10% Off with code FIRST10"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        }
      ]
    }
  ],
  "default": {
    "settings": {},
    "blocks": [
      {
        "type": "message"
      }
    ]
  }
}
{% endschema %}
