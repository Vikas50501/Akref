{%- comment -%} Recently viewed products — populated client-side from localStorage {%- endcomment -%}
{%- style -%}
  #shopify-section-{{ section.id }} { padding-top: {{ section.settings.padding_top }}px; padding-bottom: {{ section.settings.padding_bottom }}px; background: {{ section.settings.bg }}; }
{%- endstyle -%}
<recently-viewed class="recently-viewed index-section" data-limit="{{ section.settings.limit }}" data-exclude="{{ product.handle }}" hidden>
  <div class="container">
    {%- if section.settings.heading != blank -%}<h2 class="recently-viewed__heading text-center">{{ section.settings.heading }}</h2>{%- endif -%}
    <div class="recently-viewed__grid product-grid" data-recently-grid></div>
  </div>
</recently-viewed>
<script src="{{ 'recently-viewed.js' | asset_url }}" defer></script>

{% stylesheet %}
.recently-viewed__heading { margin-bottom: 32px; }
.recently-viewed__grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 24px; }
@media (max-width: 1023px) { .recently-viewed__grid { grid-template-columns: repeat(3, 1fr); } }
@media (max-width: 767px) { .recently-viewed__grid { grid-template-columns: repeat(2, 1fr); gap: 14px; } }
{% endstylesheet %}

{% schema %}
{
  "name": "t:sections.recently-viewed.name",
  "class": "index-section recently-viewed-section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "t:sections.recently-viewed.settings.heading.label",
      "default": "Recently viewed"
    },
    {
      "type": "range",
      "id": "limit",
      "label": "t:sections.recently-viewed.settings.limit.label",
      "min": 2,
      "max": 10,
      "step": 1,
      "default": 4
    },
    {
      "type": "color",
      "id": "bg",
      "label": "t:sections.recently-viewed.settings.bg.label",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "t:sections.recently-viewed.settings.padding_top.label",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "t:sections.recently-viewed.settings.padding_bottom.label",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 60
    }
  ],
  "presets": [
    {
      "name": "Recently viewed"
    }
  ]
}
{% endschema %}
