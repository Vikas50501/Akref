      },
      {
        "type": "color",
        "id": "color_sale",
        "label": "Sale / low-stock accent",
        "default": "#b12704"
      },
      {
        "type": "header",
        "content": "Buttons"
      },
      {
        "type": "color",
        "id": "color_button",
