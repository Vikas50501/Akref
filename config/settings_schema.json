        "default": "#0e3432"
      },
      {
        "type": "color",
        "id": "color_button_text",
        "label": "Button text",
        "default": "#ffffff"
      },
      {
        "type": "color",
        "id": "color_button_hover",
        "label": "Button hover",
        "default": "#141515"
      },
      {
        "type": "header",
        "content": "Announcement bar"
      },
      {
        "type": "color",
        "id": "color_announcement_bg",
        "label": "Background",
        "default": "#0e3432"
      },
      {
        "type": "color",
        "id": "color_announcement_text",
        "label": "Text",
        "default": "#ffffff"
      }
    ]
  },
  {
    "name": "Typography",
    "settings": [
      {
        "type": "paragraph",
        "content": "Brand fonts (Queens, Suisse Intl, Centra) are bundled with the theme."
      },
      {
        "type": "header",
        "content": "Type scale"
      },
      {
        "type": "range",
        "id": "h1_size",
        "label": "H1 size (desktop)",
        "min": 28,
        "max": 80,
        "step": 1,
        "unit": "px",
        "default": 48
      },
      {
        "type": "range",
        "id": "h2_size",
        "label": "H2 size (desktop)",
        "min": 20,
        "max": 56,
        "step": 1,
        "unit": "px",
        "default": 32
      },
      {
        "type": "range",
        "id": "body_size",
        "label": "Body size",
        "min": 13,
        "max": 18,
        "step": 1,
        "unit": "px",
        "default": 15
      },
      {
        "type": "select",
        "id": "heading_letter_spacing",
        "label": "Heading letter spacing",
        "options": [
          { "value": "-0.01em", "label": "Tight" },
          { "value": "0em", "label": "None" },
          { "value": "0.01em", "label": "Normal" },
          { "value": "0.04em", "label": "Wide" }
        ],
        "default": "0.01em"
      }
    ]
  },
  {
    "name": "Layout",
    "settings": [
      {
        "type": "range",
        "id": "container_width",
        "label": "Max container width",
        "min": 1200,
        "max": 1920,
        "step": 20,
        "unit": "px",
        "default": 1720
      },
      {
        "type": "range",
        "id": "container_gutter",
        "label": "Page gutter",
        "min": 0,
        "max": 40,
        "step": 1,
        "unit": "px",
        "default": 10
      },
      {
        "type": "range",
        "id": "section_spacing",
        "label": "Default space between sections",
        "min": 0,
        "max": 100,
        "step": 2,
        "unit": "px",
        "default": 0
      }
    ]
  },
  {
    "name": "Buttons & corners",
    "settings": [
      {
        "type": "range",
        "id": "button_radius",
        "label": "Button corner radius",
        "min": 0,
        "max": 40,
        "step": 1,
        "unit": "px",
        "default": 0
      },
      {
        "type": "range",
        "id": "border_radius",
        "label": "Global corner radius",
        "min": 0,
        "max": 40,
        "step": 1,
        "unit": "px",
        "default": 0
      }
    ]
  },
  {
    "name": "Product cards",
    "settings": [
      {
        "type": "checkbox",
        "id": "card_quick_add",
        "label": "Show quick add-to-cart",
        "default": true
      },
      {
        "type": "select",
        "id": "card_image_ratio",
        "label": "Card image ratio",
        "options": [
          {
            "value": "1.0",
            "label": "Square (1:1)"
          },
          {
            "value": "1.2195",
            "label": "Portrait (default)"
          },
          {
            "value": "1.5",
            "label": "Tall (2:3)"
          }
        ],
        "default": "1.2195"
      }
    ]
  },
  {
    "name": "Animations",
    "settings": [
      {
        "type": "checkbox",
        "id": "animations_enabled",
        "label": "Enable entrance & scroll animations",
        "default": true
      },
      {
        "type": "checkbox",
        "id": "parallax_enabled",
        "label": "Enable image parallax",
        "default": true
      }
    ]
  },
  {
    "name": "Cart",
    "settings": [
      {
        "type": "select",
        "id": "cart_type",
        "label": "Cart behavior",
        "options": [
          {
            "value": "drawer",
            "label": "Slide-out drawer"
          },
          {
            "value": "page",
            "label": "Cart page"
          }
        ],
        "default": "drawer"
      },
      {
        "type": "checkbox",
        "id": "cart_free_shipping_bar",
        "label": "Show free-shipping progress bar",
        "default": true
      },
      {
        "type": "range",
        "id": "cart_free_shipping_threshold",
        "label": "Free shipping threshold",
        "min": 0,
        "max": 100000,
        "step": 500,
        "default": 25000,
        "info": "In your store currency (major units)."
      },
      {
        "type": "checkbox",
        "id": "cart_show_note",
        "label": "Show order-note field",
        "default": true
      },
      {
        "type": "collection",
        "id": "cart_upsell_collection",
        "label": "Cart upsell collection",
        "info": "Shows up to 3 'you may also like' products in the cart."
      }
    ]
  },
  {
    "name": "Social & contact",
    "settings": [
      {
        "type": "text",
        "id": "social_facebook",
        "label": "Facebook URL",
        "default": "https://facebook.com/akinna.studios"
      },
      {
        "type": "text",
        "id": "social_instagram",
        "label": "Instagram URL",
        "default": "https://instagram.com/akinna.studios"
      },
      {
        "type": "text",
        "id": "social_youtube",
        "label": "YouTube URL"
      },
      {
        "type": "text",
        "id": "social_tiktok",
        "label": "TikTok URL"
      },
      {
        "type": "text",
        "id": "social_pinterest",
        "label": "Pinterest URL"
      },
      {
        "type": "text",
        "id": "social_twitter_handle",
        "label": "Twitter/X handle",
        "info": "e.g. @akinna"
      },
      {
        "type": "text",
        "id": "instagram_handle",
        "label": "Instagram handle (display)",
        "default": "@akinna.studios"
      }
    ]
  },
  {
    "name": "WhatsApp button",
    "settings": [
      {
        "type": "checkbox",
        "id": "whatsapp_enabled",
        "label": "Show floating WhatsApp button",
        "default": true
      },
      {
        "type": "text",
        "id": "whatsapp_number",
        "label": "WhatsApp number",
        "info": "Include country code, e.g. 919999999999"
      },
      {
        "type": "text",
        "id": "whatsapp_message",
        "label": "Prefilled message",
        "default": "Hi Akinna, I have a question."
      }
    ]
  },
  {
    "name": "Branding",
    "settings": [
      {
        "type": "image_picker",
        "id": "logo_dark",
        "label": "Logo (dark / for light backgrounds)"
      },
      {
        "type": "image_picker",
        "id": "logo_light",
        "label": "Logo (light / for dark backgrounds)"
      },
      {
        "type": "range",
        "id": "logo_max_height",
        "label": "Logo height",
        "min": 16,
        "max": 60,
        "step": 1,
        "unit": "px",
        "default": 30
      },
      {
        "type": "image_picker",
        "id": "favicon",
        "label": "Favicon"
      },
      {
        "type": "header",
        "content": "Social sharing (SEO)"
      },
      {
        "type": "image_picker",
        "id": "share_image",
        "label": "Default social share image",
        "info": "Used for Open Graph/Twitter when a page has no featured image (e.g. homepage)."
      }
    ]
  }
]
