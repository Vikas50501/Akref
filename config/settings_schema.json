        "default": "#f5f3f5"
      },
      {
        "type": "color",
        "id": "color_link_hover",
        "label": "Link hover",
        "default": "#3a6662"
      },
      {
        "type": "color",
        "id": "color_muted",
        "label": "Muted text",
        "default": "#5c5c5c",
