{%- comment -%}
  Bundled brand webfonts. Rendered inline in <head> so @font-face src can use
  asset_url. Keep in sync with assets/*.woff2. Queens is a TRIAL font — replace
  with a licensed build before commercial launch.
{%- endcomment -%}
<style>
  @font-face{font-family:'panamaregular';src:url({{ 'panamaproportionalregular-webfont.woff2' | asset_url }}) format('woff2');font-weight:normal;font-style:normal;font-display:swap;}
  @font-face{font-family:'suisse_intlbold';src:url({{ 'fonnts.com-suisse_intl_bold-webfont.woff2' | asset_url }}) format('woff2');font-weight:normal;font-style:normal;font-display:swap;}
  @font-face{font-family:'suisse_intlbook';src:url({{ 'fonnts.com-suisse_intl_book-webfont.woff2' | asset_url }}) format('woff2');font-weight:normal;font-style:normal;font-display:swap;}
  @font-face{font-family:'suisse_intlmedium';src:url({{ 'fonnts.com-suisse_intl_medium-webfont.woff2' | asset_url }}) format('woff2');font-weight:normal;font-style:normal;font-display:swap;}
  @font-face{font-family:'suisse_intlregular';src:url({{ 'fonnts.com-suisse_intl_regular-webfont.woff2' | asset_url }}) format('woff2');font-weight:normal;font-style:normal;font-display:swap;}
  @font-face{font-family:'suisse_intllight';src:url({{ 'fonnts.com-suisseintl-light-webfont.woff2' | asset_url }}) format('woff2');font-weight:normal;font-style:normal;font-display:swap;}
  @font-face{font-family:'suisse_intlultralight';src:url({{ 'iek12-7pwzv-webfont.woff2' | asset_url }}) format('woff2');font-weight:normal;font-style:normal;font-display:swap;}
  @font-face{font-family:'queens_var_triallight';src:url({{ 'queensvartrial-webfont.woff2' | asset_url }}) format('woff2');font-weight:100 800;font-style:normal;font-display:swap;}
  @font-face{font-family:'queens_var_italic_trialLtIt';src:url({{ 'queensvaritalictrial-webfont.woff2' | asset_url }}) format('woff2');font-weight:normal;font-style:italic;font-display:swap;}
  @font-face{font-family:'queenregular';src:url({{ 'queen-webfont.woff2' | asset_url }}) format('woff2');font-weight:normal;font-style:normal;font-display:swap;}
  @font-face{font-family:'queensemi-bold';src:url({{ 'queen_semi_bold-webfont.woff2' | asset_url }}) format('woff2');font-weight:normal;font-style:normal;font-display:swap;}
  @font-face{font-family:'queenbold';src:url({{ 'queen_bold-webfont.woff2' | asset_url }}) format('woff2');font-weight:normal;font-style:normal;font-display:swap;}
  @font-face{font-family:'queenblack';src:url({{ 'queen_black-webfont.woff2' | asset_url }}) format('woff2');font-weight:normal;font-style:normal;font-display:swap;}
  @font-face{font-family:'centra_no2book';src:url({{ 'centra_no_2_book-webfont.woff2' | asset_url }}) format('woff2');font-weight:normal;font-style:normal;font-display:swap;}
</style>
<link rel="preload" as="font" type="font/woff2" href="{{ 'queensvartrial-webfont.woff2' | asset_url }}" crossorigin>
<link rel="preload" as="font" type="font/woff2" href="{{ 'centra_no_2_book-webfont.woff2' | asset_url }}" crossorigin>
