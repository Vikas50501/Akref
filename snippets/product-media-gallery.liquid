{%- comment -%} Product media gallery — main slider + thumbnails, supports images + video {%- endcomment -%}
{%- liquid
  assign layout = section.settings.gallery_layout | default: 'thumbnails'
  assign zoom = section.settings.enable_zoom
-%}
<div class="product-gallery product-gallery--{{ layout }}{% if zoom %} product-gallery--zoom{% endif %}" data-gallery>
  <div class="product-gallery__main" data-gallery-main>
    {%- for media in product.media -%}
      <div class="product-gallery__slide{% if forloop.first %} is-active{% endif %}" data-gallery-slide data-media-id="{{ media.id }}" data-media-type="{{ media.media_type }}">
        {%- case media.media_type -%}
          {%- when 'image' -%}
            <div class="product-single__media product-single__media-image" style="--aspect-ratio: {{ media.preview_image.aspect_ratio | default: 0.75 }};">
              <img class="product-gallery__img" src="{{ media | image_url: width: 1200 }}" srcset="{{ media | image_url: width: 640 }} 640w, {{ media | image_url: width: 960 }} 960w, {{ media | image_url: width: 1200 }} 1200w, {{ media | image_url: width: 1600 }} 1600w" sizes="(max-width:1023px) 100vw, 58vw" alt="{{ media.alt | escape }}" width="{{ media.width }}" height="{{ media.height }}" {% if forloop.first %}loading="eager" fetchpriority="high"{% else %}loading="lazy"{% endif %} {% if zoom %}data-zoom-src="{{ media | image_url: width: 2400 }}"{% endif %}>
            </div>
          {%- when 'video' -%}
            <div class="product-single__media product-single__media-native-video">
              {{ media | media_tag: image_size: '1200x', controls: true, preload: 'metadata' }}
            </div>
          {%- when 'external_video' -%}
            <div class="product-single__media product-single__media-external-video">{{ media | external_video_tag }}</div>
          {%- when 'model' -%}
            <div class="product-single__media product-single__media-model">{{ media | model_viewer_tag }}</div>
          {%- else -%}
            <div class="product-single__media">{{ media | media_tag }}</div>
        {%- endcase -%}
      </div>
    {%- else -%}
      <div class="product-gallery__slide is-active" data-gallery-slide>
        <div class="product-single__media product-single__media-image">{{ 'product-1' | placeholder_svg_tag: 'placeholder-svg' }}</div>
      </div>
    {%- endfor -%}

    {%- if product.media.size > 1 -%}
      <button class="flickity-nav flickity-prev" data-gallery-prev aria-label="{{ 'accessibility.previous' | t }}">{%- render 'icon', name: 'arrow-left', size: 16 -%}</button>
      <button class="flickity-nav flickity-next" data-gallery-next aria-label="{{ 'accessibility.next' | t }}">{%- render 'icon', name: 'arrow-right', size: 16 -%}</button>
    {%- endif -%}
  </div>

  {%- if product.media.size > 1 and layout == 'thumbnails' -%}
    <div class="product-thumbnail-container" data-gallery-thumbs>
      {%- for media in product.media -%}
        <button class="product-thumbnail{% if forloop.first %} is-initial-selected{% endif %}" data-gallery-thumb data-media-id="{{ media.id }}" aria-label="{{ media.alt | default: 'Media' | escape }}">
          <img src="{{ media.preview_image | image_url: width: 168 }}" alt="{{ media.alt | escape }}" width="84" height="112" loading="lazy">
          {%- if media.media_type == 'video' -%}<span class="product-thumbnail-icon">{%- render 'icon', name: 'play', size: 14 -%}</span>{%- endif -%}
        </button>
      {%- endfor -%}
    </div>
  {%- endif -%}
</div>
