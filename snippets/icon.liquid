{%- comment -%}
  Inline SVG icon library. Usage: {% render 'icon', name: 'cart', size: 20 %}
  Icons inherit currentColor. Stroke icons use fill:none.
{%- endcomment -%}
{%- liquid
  assign s = size | default: 22
-%}
{%- case name -%}
  {%- when 'menu' -%}
    <svg class="icon icon--menu" width="{{ s }}" height="{{ s }}" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M3 6h18M3 12h18M3 18h18" stroke="currentColor" stroke-width="1.4"/></svg>
  {%- when 'close' -%}
    <svg class="icon icon--close" width="{{ s }}" height="{{ s }}" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M5 5l14 14M19 5L5 19" stroke="currentColor" stroke-width="1.4"/></svg>
  {%- when 'search' -%}
    <svg class="icon icon--search" width="{{ s }}" height="{{ s }}" viewBox="0 0 22 22" fill="none" aria-hidden="true"><circle cx="10" cy="10" r="7" stroke="currentColor" stroke-width="1.3"/><path d="M15 15l5 5" stroke="currentColor" stroke-width="1.3"/></svg>
  {%- when 'account' -%}
    <svg class="icon icon--account" width="{{ s }}" height="{{ s }}" viewBox="0 0 20 22" fill="none" aria-hidden="true"><circle cx="10" cy="6" r="4" stroke="currentColor" stroke-width="1.3"/><path d="M2 21c0-4.4 3.6-8 8-8s8 3.6 8 8" stroke="currentColor" stroke-width="1.3"/></svg>
  {%- when 'cart' -%}
    <svg class="icon icon--cart" width="{{ s }}" height="{{ s }}" viewBox="0 0 20 22" fill="none" aria-hidden="true"><path d="M2 6h16l-1.2 13.2a2 2 0 0 1-2 1.8H5.2a2 2 0 0 1-2-1.8L2 6z" stroke="currentColor" stroke-width="1.3"/><path d="M6.5 6V4.5a3.5 3.5 0 0 1 7 0V6" stroke="currentColor" stroke-width="1.3"/></svg>
  {%- when 'arrow-right' -%}
    <svg class="icon icon--arrow-right" width="{{ s }}" height="{{ s }}" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M4 12h16M14 6l6 6-6 6" stroke="currentColor" stroke-width="1.3"/></svg>
  {%- when 'arrow-up-right' -%}
    <svg class="icon icon--arrow-up-right" width="{{ s }}" height="{{ s }}" viewBox="0 0 10 10" fill="none" aria-hidden="true"><path d="M1 1H9M9 1V9M9 1L1 9" stroke="currentColor" stroke-width="1.2"/></svg>
  {%- when 'arrow-left' -%}
    <svg class="icon icon--arrow-left" width="{{ s }}" height="{{ s }}" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M20 12H4M10 6l-6 6 6 6" stroke="currentColor" stroke-width="1.3"/></svg>
  {%- when 'chevron-down' -%}
    <svg class="icon icon--chevron-down" width="{{ s }}" height="{{ s }}" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M6 9l6 6 6-6" stroke="currentColor" stroke-width="1.4"/></svg>
  {%- when 'chevron-right' -%}
    <svg class="icon icon--chevron-right" width="{{ s }}" height="{{ s }}" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M9 6l6 6-6 6" stroke="currentColor" stroke-width="1.4"/></svg>
  {%- when 'plus' -%}
    <svg class="icon icon--plus" width="{{ s }}" height="{{ s }}" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M12 5v14M5 12h14" stroke="currentColor" stroke-width="1.4"/></svg>
  {%- when 'minus' -%}
    <svg class="icon icon--minus" width="{{ s }}" height="{{ s }}" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M5 12h14" stroke="currentColor" stroke-width="1.4"/></svg>
  {%- when 'star' -%}
    <svg class="icon icon--star" width="{{ s }}" height="{{ s }}" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 2l2.9 6.3 6.9.7-5.1 4.6 1.4 6.8L12 17.8 5.9 20.4l1.4-6.8L2.2 9l6.9-.7L12 2z"/></svg>
  {%- when 'quote' -%}
    <svg class="icon icon--quote" width="{{ s }}" height="{{ s }}" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M10 7H5a3 3 0 0 0-3 3v7h7v-7H4.5A1.5 1.5 0 0 1 6 8.5V7zm12 0h-5a3 3 0 0 0-3 3v7h7v-7h-3.5A1.5 1.5 0 0 1 18 8.5V7z"/></svg>
  {%- when 'play' -%}
    <svg class="icon icon--play" width="{{ s }}" height="{{ s }}" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M6 4l14 8-14 8V4z"/></svg>
  {%- when 'pause' -%}
    <svg class="icon icon--pause" width="{{ s }}" height="{{ s }}" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M7 4h4v16H7zM13 4h4v16h-4z"/></svg>
  {%- when 'filter' -%}
    <svg class="icon icon--filter" width="{{ s }}" height="{{ s }}" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M3 5h18M6 12h12M10 19h4" stroke="currentColor" stroke-width="1.4"/></svg>
  {%- when 'facebook' -%}
    <svg class="icon icon--facebook" width="{{ s }}" height="{{ s }}" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M14 9h3V5h-3c-2.2 0-4 1.8-4 4v2H7v4h3v6h4v-6h3l1-4h-4V9c0-.6.4-1 1-1z"/></svg>
  {%- when 'instagram' -%}
    <svg class="icon icon--instagram" width="{{ s }}" height="{{ s }}" viewBox="0 0 24 24" fill="none" aria-hidden="true"><rect x="3" y="3" width="18" height="18" rx="5" stroke="currentColor" stroke-width="1.4"/><circle cx="12" cy="12" r="4" stroke="currentColor" stroke-width="1.4"/><circle cx="17.5" cy="6.5" r="1" fill="currentColor"/></svg>
  {%- when 'youtube' -%}
    <svg class="icon icon--youtube" width="{{ s }}" height="{{ s }}" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M23 12s0-3.4-.4-5a2.6 2.6 0 0 0-1.8-1.8C19 5 12 5 12 5s-7 0-8.8.2A2.6 2.6 0 0 0 1.4 7C1 8.6 1 12 1 12s0 3.4.4 5a2.6 2.6 0 0 0 1.8 1.8C5 19 12 19 12 19s7 0 8.8-.2A2.6 2.6 0 0 0 22.6 17c.4-1.6.4-5 .4-5zM10 15V9l5 3-5 3z"/></svg>
  {%- when 'whatsapp' -%}
    <svg class="icon icon--whatsapp" width="{{ s }}" height="{{ s }}" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 2a10 10 0 0 0-8.5 15.3L2 22l4.8-1.5A10 10 0 1 0 12 2zm5.6 14.2c-.2.6-1.2 1.2-1.7 1.2-.5.1-1 .1-3.3-.9-2.8-1.2-4.5-4-4.7-4.2-.1-.2-1.1-1.5-1.1-2.8s.7-2 .9-2.2c.2-.3.5-.3.7-.3h.5c.2 0 .4 0 .6.5l.8 2c.1.2.1.4 0 .5l-.4.6c-.2.2-.3.4-.1.7.2.3.9 1.4 1.9 2.3 1.3 1.1 2.3 1.5 2.6 1.6.2.1.4.1.6-.1l.9-1c.2-.3.4-.2.7-.1l2 .9c.3.2.5.2.5.4.1.2.1.8-.2 1.4z"/></svg>
  {%- when 'heart' -%}
    <svg class="icon icon--heart" width="{{ s }}" height="{{ s }}" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M12 20.5s-7.5-4.6-10-9.3C.4 8 1.7 4.5 5 3.4c2.3-.8 4.6.1 6 2 1.4-1.9 3.7-2.8 6-2 3.3 1.1 4.6 4.6 3 7.8-2.5 4.7-10 9.3-10 9.3z" stroke="currentColor" stroke-width="1.3"/></svg>
  {%- when 'heart-filled' -%}
    <svg class="icon icon--heart-filled" width="{{ s }}" height="{{ s }}" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 20.5s-7.5-4.6-10-9.3C.4 8 1.7 4.5 5 3.4c2.3-.8 4.6.1 6 2 1.4-1.9 3.7-2.8 6-2 3.3 1.1 4.6 4.6 3 7.8-2.5 4.7-10 9.3-10 9.3z"/></svg>
  {%- when 'eye' -%}
    <svg class="icon icon--eye" width="{{ s }}" height="{{ s }}" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M1 12s4-7 11-7 11 7 11 7-4 7-11 7-11-7-11-7z" stroke="currentColor" stroke-width="1.3"/><circle cx="12" cy="12" r="3" stroke="currentColor" stroke-width="1.3"/></svg>
  {%- when 'cart-empty' -%}
    <svg class="icon icon--cart-empty" width="{{ s }}" height="{{ s }}" viewBox="0 0 48 48" fill="none" aria-hidden="true"><path d="M6 12h36l-3 28a3 3 0 0 1-3 2.7H12A3 3 0 0 1 9 40L6 12z" stroke="currentColor" stroke-width="1.4"/><path d="M16 12V9a8 8 0 0 1 16 0v3" stroke="currentColor" stroke-width="1.4"/></svg>
  {%- else -%}
    {%- comment -%} unknown icon: render nothing {%- endcomment -%}
{%- endcase -%}
